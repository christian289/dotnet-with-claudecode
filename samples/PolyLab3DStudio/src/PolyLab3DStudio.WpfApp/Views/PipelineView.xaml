<UserControl x:Class="PolyLab3DStudio.Views.PipelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PolyLab3DStudio.Controls"
             Background="{StaticResource PaperBrush}">
    <UserControl.Resources>

        <!-- Term-tip style lives in GuideStyles.xaml (shared with the tool map screen). -->

        <!-- One clickable pipeline stage (both lanes; colors switch on IsUiLane / IsSelected). -->
        <DataTemplate x:Key="PipelineStageTemplate">
            <DockPanel>
                <Viewbox x:Name="Arrow" DockPanel.Dock="Right" Width="16" Height="16"
                         Margin="4,0" VerticalAlignment="Center">
                    <Canvas Width="24" Height="24">
                        <Path x:Name="ArrowPath"
                              Data="M4 12h15M14 6l6 6-6 6"
                              Stroke="{StaticResource IndigoBrush}" StrokeThickness="2.4"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                    </Canvas>
                </Viewbox>
                <Button Command="{Binding SelectCommand}" Cursor="Hand" Focusable="False"
                        AutomationProperties.Name="{Binding Name}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Chrome"
                                    Background="{StaticResource PipelineStageIdleBrush}"
                                    BorderBrush="Transparent" BorderThickness="2"
                                    CornerRadius="12" Padding="12,11">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="11" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="IconChip" Width="36" Height="36" CornerRadius="10"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource PipelineUiIconRingBrush}"
                                            BorderThickness="1.5" VerticalAlignment="Center">
                                        <Viewbox Width="19" Height="19">
                                            <Canvas Width="24" Height="24">
                                                <Path x:Name="IconPath"
                                                      Data="{Binding Icon, Converter={StaticResource StringToGeometry}}"
                                                      Stroke="{StaticResource IndigoBrush}" StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock TextTrimming="CharacterEllipsis">
                                            <Run x:Name="NumRun"
                                                 Text="{Binding Num, Mode=OneWay}"
                                                 FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource IndigoBrush}" /><Run Text=" " /><Run
                                                 Text="{Binding Name, Mode=OneWay}" FontSize="14.5"
                                                 FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                        </TextBlock>
                                        <TextBlock x:Name="Sub" Text="{Binding Sub}" FontSize="11.5"
                                                   Foreground="{StaticResource PipelineStageSubIdleBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsUiLane}" Value="False">
                                    <Setter TargetName="IconChip" Property="BorderBrush" Value="{StaticResource PipelineWarmIconRingBrush}" />
                                    <Setter TargetName="IconPath" Property="Stroke" Value="{StaticResource PipelineWarmBrush}" />
                                    <Setter TargetName="NumRun" Property="Foreground" Value="{StaticResource PipelineWarmBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceBrush}" />
                                    <Setter TargetName="Sub" Property="Foreground" Value="{StaticResource BodyBrush}" />
                                    <Setter TargetName="IconPath" Property="Stroke" Value="{StaticResource SurfaceBrush}" />
                                    <Setter TargetName="Chrome" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="{StaticResource InkShadowColor}" Opacity="0.14" BlurRadius="20"
                                                              ShadowDepth="8" Direction="270" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSelected}" Value="True" />
                                        <Condition Binding="{Binding IsUiLane}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource IndigoBrush}" />
                                    <Setter TargetName="IconChip" Property="Background" Value="{StaticResource IndigoBrush}" />
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSelected}" Value="True" />
                                        <Condition Binding="{Binding IsUiLane}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource PipelineWarmBrush}" />
                                    <Setter TargetName="IconChip" Property="Background" Value="{StaticResource PipelineWarmBrush}" />
                                </MultiDataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </DockPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsLastInLane}" Value="True">
                    <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUiLane}" Value="False">
                    <Setter TargetName="ArrowPath" Property="Stroke" Value="{StaticResource PipelineWarmBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </UserControl.Resources>

    <DockPanel>

        <!-- Sticky header -->
        <Border DockPanel.Dock="Top"
                Height="60"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}"
                BorderThickness="0,0,0,1"
                Padding="28,0">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource BackButton}" Command="{Binding GoStartCommand}"
                        AutomationProperties.Name="파이프라인 뒤로" VerticalAlignment="Center" />
                <ContentControl ContentTemplate="{StaticResource LogoIconTemplate}"
                                Content=""
                                Focusable="False"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0" />
                <TextBlock Text="WPF 코어: 화면에 그려지기까지" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="14,0,0,0" />
                <TextBlock Style="{StaticResource TaglineMonoText}"
                           Text="RENDER PIPELINE"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly">
            <StackPanel MaxWidth="920" Margin="24,32,24,64">

                <!-- Intro -->
                <StackPanel Margin="0,0,0,28">
                    <TextBlock FontSize="26" FontWeight="Bold" TextWrapping="Wrap"
                               LineHeight="36.4" LineStackingStrategy="BlockLineHeight"
                               Text="내 XAML은 어떤 길을 지나 픽셀이 될까?" />
                    <TextBlock Margin="0,10,0,0" MaxWidth="640" HorizontalAlignment="Left"
                               FontSize="14" Foreground="{StaticResource BodyBrush}"
                               TextWrapping="Wrap" LineHeight="23.8" LineStackingStrategy="BlockLineHeight">
                        <Run Text="아래 단계를 클릭해 보세요. WPF는 두 개의 스레드로 나뉘어 일해요 — 여러분의 코드가 사는 " /><Run
                             Text="UI 스레드" FontWeight="Bold" Foreground="{StaticResource IndigoBrush}" /><Run
                             Text=", 그리고 우리가 만질 수 없는 " /><Run
                             Text="렌더 스레드" FontWeight="Bold" Foreground="{StaticResource PipelineWarmBrush}" /><Run
                             Text=". 이 경계를 이해하면 " /><controls:TermTip Word="Freeze()" /><Run
                             Text="의 의미도, DX12 브릿지가 필요한 이유도 명확해집니다." />
                    </TextBlock>
                </StackPanel>

                <!-- Pipeline diagram -->
                <Border Style="{StaticResource GuideCardBorder}" CornerRadius="16" Padding="20" Margin="0,0,0,28">
                    <StackPanel>

                        <!-- UI thread lane -->
                        <Border Background="{StaticResource PipelineUiLaneBrush}"
                                BorderBrush="{StaticResource PipelineUiLaneBorderBrush}"
                                BorderThickness="1" CornerRadius="14" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,11">
                                    <Viewbox Width="19" Height="19" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Ellipse Canvas.Left="8" Canvas.Top="4" Width="8" Height="8"
                                                     Stroke="{StaticResource IndigoBrush}" StrokeThickness="1.8" />
                                            <Path Data="M4 21c0-4 3.6-6.5 8-6.5s8 2.5 8 6.5"
                                                  Stroke="{StaticResource IndigoBrush}" StrokeThickness="1.8"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="UI 스레드" FontSize="13.5" FontWeight="ExtraBold"
                                               Foreground="{StaticResource IndigoBrush}"
                                               VerticalAlignment="Center" Margin="9,0,0,0" />
                                    <TextBlock Text="— 여러분의 코드가 사는 곳 · 만들고, 배치하고, 이벤트를 받는다"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource PipelineUiSubBrush}"
                                               VerticalAlignment="Center" Margin="9,0,0,0" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding UiStages}"
                                              ItemTemplate="{StaticResource PipelineStageTemplate}"
                                              Focusable="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Thread boundary -->
                        <Grid Margin="0,6">
                            <Viewbox Width="18" Height="34" HorizontalAlignment="Left" Margin="32,0,0,0">
                                <Canvas Width="18" Height="34">
                                    <Path Data="M9 2v24M4 21l5 5 5-5"
                                          Stroke="{StaticResource PipelineBoundaryArrowBrush}" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                </Canvas>
                            </Viewbox>
                            <Viewbox Width="18" Height="34" HorizontalAlignment="Right" Margin="0,0,32,0">
                                <Canvas Width="18" Height="34">
                                    <Path Data="M9 2v24M4 21l5 5 5-5"
                                          Stroke="{StaticResource PipelineBoundaryArrowBrush}" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                </Canvas>
                            </Viewbox>
                            <Grid HorizontalAlignment="Center" Margin="0,4">
                                <Rectangle RadiusX="21" RadiusY="21"
                                           Fill="{StaticResource PipelineBoundaryBrush}"
                                           Stroke="{StaticResource PointSandBrush}" StrokeThickness="1.5"
                                           StrokeDashArray="4 3" />
                                <StackPanel Orientation="Horizontal" Margin="18,9">
                                    <Viewbox Width="17" Height="17" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Rectangle Canvas.Left="4" Canvas.Top="10" Width="16" Height="10"
                                                       RadiusX="2" RadiusY="2"
                                                       Stroke="{StaticResource MissionFgBrush}" StrokeThickness="1.8" />
                                            <Path Data="M8 10V7a4 4 0 018 0v3"
                                                  Stroke="{StaticResource MissionFgBrush}" StrokeThickness="1.8"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock FontSize="12.5" FontWeight="Bold"
                                               Foreground="{StaticResource PipelineBoundaryFgBrush}"
                                               VerticalAlignment="Center" Margin="10,0,0,0">
                                        <Run Text="스레드 경계 · " /><controls:TermTip Word="DUCE 채널" />
                                    </TextBlock>
                                    <TextBlock FontSize="11.5"
                                               Foreground="{StaticResource MissionFgBrush}"
                                               VerticalAlignment="Center" Margin="10,0,0,0">
                                        <Run Text="여기를 건널 때 복사·동기화가 일어나요 → " /><controls:TermTip Word="Freeze()" /><Run
                                             Text="가 중요한 이유" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Render thread lane -->
                        <Border Background="{StaticResource PipelineRenderLaneBrush}"
                                BorderBrush="{StaticResource PipelineRenderLaneBorderBrush}"
                                BorderThickness="1" CornerRadius="14" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,11">
                                    <Viewbox Width="19" Height="19" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Rectangle Canvas.Left="7" Canvas.Top="7" Width="10" Height="10"
                                                       RadiusX="1.5" RadiusY="1.5"
                                                       Stroke="{StaticResource PipelineWarmBrush}" StrokeThickness="1.8" />
                                            <Path Data="M7 3v2M12 3v2M17 3v2M7 19v2M12 19v2M17 19v2M3 7h2M3 12h2M3 17h2M19 7h2M19 12h2M19 17h2"
                                                  Stroke="{StaticResource PipelineWarmBrush}" StrokeThickness="1.8"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="렌더 스레드" FontSize="13.5" FontWeight="ExtraBold"
                                               Foreground="{StaticResource PipelineWarmBrush}"
                                               VerticalAlignment="Center" Margin="9,0,0,0" />
                                    <TextBlock Text="— milcore의 영역 · 우리가 직접 만질 수 없는 곳"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource PipelineWarmBrush}"
                                               VerticalAlignment="Center" Margin="9,0,0,0" />
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding RenderStages}"
                                              ItemTemplate="{StaticResource PipelineStageTemplate}"
                                              Focusable="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Detail panel -->
                        <Border Background="{StaticResource HeaderBrush}"
                                BorderBrush="{StaticResource BorderSoftBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="20,18" Margin="0,14,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock>
                                        <Run Text="{Binding Selected.Num, Mode=OneWay}"
                                             FontFamily="{StaticResource MonoFont}" FontSize="13"
                                             FontWeight="Bold" Foreground="{StaticResource AccentBrush}" /><Run Text=" " /><Run
                                             Text="{Binding Selected.Name, Mode=OneWay}"
                                             FontSize="17" FontWeight="Bold" Foreground="{StaticResource InkBrush}" />
                                    </TextBlock>
                                    <Border CornerRadius="6" Padding="10,3" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource PipelineWarmTintBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Selected.IsUiLane}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource IndigoTintBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Selected.LaneLabel}" FontSize="11.5" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource PipelineWarmBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Selected.IsUiLane}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource IndigoBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Selected.Paras}" Focusable="False">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="14"
                                                       Foreground="{StaticResource InkSoftBrush}"
                                                       TextWrapping="Wrap" LineHeight="24.5"
                                                       LineStackingStrategy="BlockLineHeight"
                                                       Margin="0,10,0,0" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Where does 3D fit -->
                <Border Style="{StaticResource GuideCardBorder}" CornerRadius="16" Padding="22,20" Margin="0,0,0,28">
                    <StackPanel>
                        <TextBlock Text="3D는 이 파이프라인의 어디에 끼나요?" FontSize="16" FontWeight="Bold" />
                        <TextBlock Margin="0,10,0,0" FontSize="13" Foreground="{StaticResource BodyBrush}"
                                   TextWrapping="Wrap" LineHeight="22.1" LineStackingStrategy="BlockLineHeight">
                            <controls:TermTip Word="Viewport3D" /><Run
                                 Text="는 특별한 존재가 아니라 " /><Run
                                 Text="비주얼 트리의 Visual 하나" FontWeight="Bold" /><Run
                                 Text="예요. 여러분이 만든 " /><controls:TermTip Word="MeshGeometry3D" /><Run
                                 Text="·Material·Transform은 UI 스레드에서 정의되고, DUCE 채널을 건너 합성 트리에 복제된 뒤, " /><Run
                                 Text="실제 삼각형 " FontWeight="Bold" /><controls:TermTip Word="래스터화" FontWeight="Bold" /><Run
                                 Text="는 ⑤ DirectX 단계" FontWeight="Bold" /><Run
                                 Text="에서 일어나요. 그래서 3D 데이터가 자주 안 바뀐다면 " /><controls:TermTip Word="Freeze()" /><Run
                                 Text="로 동결하는 것이 성능에 큰 도움이 됩니다." />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- External DX12 entry points -->
                <Border Background="{StaticResource DarkCardBrush}" CornerRadius="16" Padding="24,22">
                    <StackPanel>
                        <TextBlock Text="그래서 외부 DX12는 어떻게 들어오나" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource SurfaceBrush}" />
                        <TextBlock Margin="0,12,0,0" FontSize="13" Foreground="{StaticResource DarkBodyBrush}"
                                   TextWrapping="Wrap" LineHeight="22.1" LineStackingStrategy="BlockLineHeight">
                            <Run Text="합성 표면은 " /><controls:TermTip Word="milcore" /><Run
                                 Text="가 독점하므로, 외부 DirectX가 WPF 화면에 들어오는 길은 둘뿐이에요. 이것이 트랙 B-3(DX12 브릿지)의 근거입니다." />
                        </TextBlock>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource PipelineDarkChipBrush}"
                                    BorderBrush="{StaticResource PipelineDarkChipBorderBrush}"
                                    BorderThickness="1" CornerRadius="11" Padding="16,14">
                                <StackPanel>
                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource YellowBrush}">
                                        <Run Text="① " /><controls:TermTip Word="D3DImage" /><Run
                                             Text=" 브릿지" />
                                    </TextBlock>
                                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10.5"
                                               Foreground="{StaticResource DarkMutedBrush}"
                                               LineHeight="17.9" LineStackingStrategy="BlockLineHeight"
                                               Margin="0,6,0,0">
                                        <Run Text="DX12 렌더 → 공유 DXGI 리소스" /><LineBreak /><Run
                                             Text="→ D3D11On12 → D3D11Image" /><LineBreak /><Run
                                             Text="→ D3DImage(D3D9) → WPF 합성" />
                                    </TextBlock>
                                    <TextBlock Text="WPF UI를 3D 위에 겹칠 수 있음 · 매 프레임 복사 비용"
                                               FontSize="11.5" Foreground="{StaticResource DarkBodyBrush}"
                                               TextWrapping="Wrap" LineHeight="18.4"
                                               LineStackingStrategy="BlockLineHeight" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2"
                                    Background="{StaticResource PipelineDarkChipBrush}"
                                    BorderBrush="{StaticResource PipelineDarkChipBorderBrush}"
                                    BorderThickness="1" CornerRadius="11" Padding="16,14">
                                <StackPanel>
                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource YellowBrush}">
                                        <Run Text="② " /><controls:TermTip Word="HwndHost" /><Run Text=" " /><controls:TermTip Word="에어스페이스" />
                                    </TextBlock>
                                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10.5"
                                               Foreground="{StaticResource DarkMutedBrush}"
                                               LineHeight="17.9" LineStackingStrategy="BlockLineHeight"
                                               Margin="0,6,0,0">
                                        <Run Text="자식 HWND 생성" /><LineBreak /><Run
                                             Text="→ DXGI 스왑체인" /><LineBreak /><Run
                                             Text="→ DX12가 직접 렌더·프레젠트" />
                                    </TextBlock>
                                    <TextBlock Text="DX12 본연의 성능 · 그 위에 WPF 요소 못 얹음"
                                               FontSize="11.5" Foreground="{StaticResource DarkBodyBrush}"
                                               TextWrapping="Wrap" LineHeight="18.4"
                                               LineStackingStrategy="BlockLineHeight" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Button Style="{StaticResource AccentButton}"
                                Content="트랙 B에서 자세히 배우기 →"
                                Command="{Binding GoCoursesCommand}"
                                FontSize="12.5" FontWeight="Bold" Padding="16,10"
                                HorizontalAlignment="Left" Margin="0,14,0,0" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
