<UserControl x:Class="PolyLab3DStudio.Views.GuideView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PolyLab3DStudio"
             Background="{StaticResource PaperBrush}">
    <DockPanel>

        <!-- Sticky header -->
        <Border DockPanel.Dock="Top"
                Height="60"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}"
                BorderThickness="0,0,0,1"
                Padding="28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Style="{StaticResource BackButton}" Command="{Binding GoStartCommand}" AutomationProperties.Name="가이드 뒤로" VerticalAlignment="Center" />
                <ContentControl Grid.Column="1"
                                ContentTemplate="{StaticResource LogoIconTemplate}"
                                Content=""
                                Focusable="False"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="도구 개념 가이드" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Style="{StaticResource TaglineMonoText}"
                               Text="GIMP · INKSCAPE · BLENDER · POINT CLOUD"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>
                <Button Grid.Column="4"
                        Style="{StaticResource AccentButton}"
                        Content="폴리랩에서 연습하기"
                        Command="{Binding GoStudioFreeCommand}"
                        FontSize="12.5" Padding="14,8"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly">
            <StackPanel MaxWidth="860" Margin="24,36,24,72">

                <!-- Intro -->
                <StackPanel Margin="0,0,0,40">
                    <TextBlock Style="{StaticResource H1Text}">GIMP · Inkscape · Blender,<LineBreak />어떻게 만들고 어떻게 움직일까?</TextBlock>
                    <TextBlock Style="{StaticResource LeadText}"
                               MaxWidth="620"
                               HorizontalAlignment="Left"
                               Margin="0,14,0,0"
                               Text="세 도구 모두 강력한 무료 도구지만, 다루는 &quot;재료&quot;가 서로 달라요. 재료가 무엇인지 이해하면 어렵게 느껴지던 메뉴들이 한결 단순해집니다. 폴리랩에서 익힌 개념이 어디에 그대로 통하는지도 함께 표시해 두었어요." />
                </StackPanel>

                <!-- 01 Three graphic worlds -->
                <StackPanel Margin="0,0,0,40">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource SectionNumberText}" Text="01" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                        <TextBlock Style="{StaticResource H2Text}" Text="세 가지 그래픽 세계" VerticalAlignment="Bottom" Margin="10,0,0,0" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ContentControl Focusable="False"
                                        Content="{Binding WorldCards[0]}"
                                        ContentTemplate="{StaticResource WorldCardTemplate}" />
                        <ContentControl Grid.Column="2" Focusable="False"
                                        Content="{Binding WorldCards[1]}"
                                        ContentTemplate="{StaticResource WorldCardTemplate}" />
                        <ContentControl Grid.Column="4" Focusable="False"
                                        Content="{Binding WorldCards[2]}"
                                        ContentTemplate="{StaticResource WorldCardTemplate}" />
                    </Grid>
                    <Border Style="{StaticResource CalloutBorder}" Margin="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource CalloutLabelText}" Text="TIP" VerticalAlignment="Top" />
                            <TextBlock Grid.Column="1" Style="{StaticResource CalloutText}">
                                <Run Text="&quot;모델링&quot;이라는 말은 3D 세계의 용어예요. GIMP·Inkscape에서는 입체를 만드는 대신, 픽셀을 칠하거나(GIMP) 선을 그리는(Inkscape) 방식으로 이미지를 만들어요. 그리고 현실의 물체를 3D로 가져오는 " /><Run Text="포인트 클라우드" FontWeight="Bold" /><Run Text="라는 네 번째 세계도 있어요 — 아래 " /><Hyperlink Click="OnPointCloudLinkClick"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold"
                                           TextDecorations="{x:Null}">06번</Hyperlink><Run Text="에서 소개할게요." />
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- 02-04 GIMP / Inkscape / Blender -->
                <ItemsControl ItemsSource="{Binding ToolSections}"
                              ItemTemplate="{StaticResource ToolGuideSectionTemplate}" />

                <!-- 05 Comparison & licenses -->
                <StackPanel Margin="0,0,0,40">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource SectionNumberText}" Text="05" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                        <TextBlock Style="{StaticResource H2Text}" Text="한눈 비교 &amp; 라이선스" VerticalAlignment="Bottom" Margin="10,0,0,0" />
                    </StackPanel>
                    <Border Style="{StaticResource GuideCardBorder}">
                        <StackPanel>
                            <Border Background="{StaticResource HeaderBrush}"
                                    CornerRadius="13,13,0,0"
                                    BorderBrush="{StaticResource BorderSoftBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="1">
                                        <TextBlock Text="GIMP" FontSize="13.5" FontWeight="Bold" Margin="14,12" />
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1,0,0,0">
                                        <TextBlock Text="Inkscape" FontSize="13.5" FontWeight="Bold" Margin="14,12" />
                                    </Border>
                                    <Border Grid.Column="3" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1,0,0,0">
                                        <TextBlock Text="Blender" FontSize="13.5" FontWeight="Bold" Margin="14,12" />
                                    </Border>
                                </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding ComparisonRows}"
                                          ItemTemplate="{StaticResource ComparisonRowTemplate}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CalloutBorder}" Margin="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource CalloutLabelText}" Text="라이선스" VerticalAlignment="Top" />
                            <TextBlock Grid.Column="1" Style="{StaticResource CalloutText}">
                                <Run Text="세 도구 모두 " /><Run Text="GPL 계열 오픈소스" FontWeight="Bold" /><Run Text="라 개인·회사·학교 어디서든 " /><Run Text="완전 무료" FontWeight="Bold" /><Run Text="로 쓸 수 있고, 상업 작업에 사용해도 됩니다. GPL은 &quot;프로그램 자체&quot;에 대한 규칙이라, 여러분이 만든 " /><Run Text="작품의 저작권은 온전히 여러분 것" FontWeight="Bold" /><Run Text="이에요. 프로그램의 소스 코드를 고쳐서 배포할 때만 소스 공개 의무가 생깁니다." />
                            </TextBlock>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- 06 Point cloud -->
                <StackPanel x:Name="PointCloudSection" Margin="0,0,0,40">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource SectionNumberText}" Text="06" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                        <TextBlock Style="{StaticResource H2Text}" Text="번외: 포인트 클라우드" VerticalAlignment="Bottom" Margin="10,0,0,0" />
                        <TextBlock Style="{StaticResource TaglineMonoText}"
                                   Text="POINT CLOUD — 현실을 3D로 가져오기"
                                   VerticalAlignment="Bottom"
                                   Margin="10,0,0,3" />
                    </StackPanel>
                    <Border Style="{StaticResource GuideCardBorder}" Padding="22,20">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ContentControl ContentTemplate="{StaticResource PointCloudIconTemplate}"
                                                Content=""
                                                Focusable="False"
                                                VerticalAlignment="Top"
                                                Margin="0,0,18,0" />
                                <TextBlock Grid.Column="1"
                                           FontSize="13.5"
                                           Foreground="{StaticResource BodyBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="23"
                                           LineStackingStrategy="BlockLineHeight"
                                           local:BoldableText.Text="[[포인트 클라우드]]는 **3D 스캐너, LiDAR(아이폰 프로에도 있어요!), 사진측량**이 만들어내는 결과물이에요. 수십만~수백만 개의 점이 공간에 흩뿌려져 있고, 점 하나하나가 **위치(X·Y·Z)와 색**을 가져요. 폴리랩에서 배운 좌표 개념 그대로, 점만 아주 많아진 거예요." />
                            </Grid>
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ContentControl Focusable="False"
                                                Content="{Binding PointCloudBullets[0]}"
                                                ContentTemplate="{StaticResource BulletTemplate}" />
                                <ContentControl Grid.Column="2" Focusable="False"
                                                Content="{Binding PointCloudBullets[1]}"
                                                ContentTemplate="{StaticResource BulletTemplate}" />
                            </Grid>
                            <Rectangle Style="{StaticResource CardDivider}" />
                            <TextBlock Style="{StaticResource SubLabelText}" Text="기본 작업 흐름 · WORKFLOW" />
                            <ItemsControl ItemsSource="{Binding PointCloudWorkflow}"
                                          AlternationCount="99"
                                          ItemTemplate="{StaticResource WorkflowStepTemplate}"
                                          Margin="0,0,0,-8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <Rectangle Style="{StaticResource CardDivider}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ContentControl Focusable="False"
                                                Content="{Binding PointCloudTools[0]}"
                                                ContentTemplate="{StaticResource MiniToolCardTemplate}" />
                                <ContentControl Grid.Column="2" Focusable="False"
                                                Content="{Binding PointCloudTools[1]}"
                                                ContentTemplate="{StaticResource MiniToolCardTemplate}" />
                            </Grid>
                            <TextBlock FontSize="11.5"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,14,0,0">
                                <Run Text="대표 파일 형식: " /><Run Text="PLY · LAS · E57 · XYZ"
                                     FontFamily="{StaticResource MonoFont}"
                                     FontSize="10.5" /><Run Text=" — 점의 좌표와 색을 담아요." />
                            </TextBlock>
                            <Border Style="{StaticResource TintCalloutBorder}" Margin="0,14,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CalloutLabelText}" Text="실습" VerticalAlignment="Top" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CalloutText}">
                                        <Hyperlink Command="{Binding GoStudioFreeCommand}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" TextDecorations="{x:Null}">폴리랩 스튜디오</Hyperlink><Run Text="의 [포인트 클라우드] 그룹에서 점 구·점 도넛·점 지형을 직접 만들어 돌려볼 수 있어요. XAML 내보내기를 하면 WPF용 포인트 클라우드 렌더링 코드도 함께 생성돼요." />
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Closing CTA -->
                <Border Background="{StaticResource DarkCardBrush}" CornerRadius="16" Padding="28,26">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="개념은 하나, 도구는 여럿"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SurfaceBrush}" />
                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource DarkBodyBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="21.5"
                                       LineStackingStrategy="BlockLineHeight"
                                       Margin="0,6,0,0"
                                       Text="선택 → 변형(이동·회전·크기) → 재질/색 → 내보내기. 폴리랩에서 익힌 이 흐름은 GIMP, Inkscape, Blender 어디서나 똑같이 반복돼요. 도구가 바뀌어도 여러분이 배운 것은 사라지지 않아요." />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Style="{StaticResource AccentButton}"
                                Content="폴리랩으로 돌아가기 →"
                                Command="{Binding GoStartCommand}"
                                FontSize="13.5"
                                FontWeight="Bold"
                                Padding="20,12"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
