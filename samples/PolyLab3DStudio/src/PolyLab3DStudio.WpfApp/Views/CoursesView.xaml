<UserControl x:Class="PolyLab3DStudio.Views.CoursesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PolyLab3DStudio.ViewModels;assembly=PolyLab3DStudio.ViewModels">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="0,0,0,1"
                Padding="28,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Style="{StaticResource BackButton}" Command="{Binding GoStartCommand}" VerticalAlignment="Center" AutomationProperties.Name="뒤로" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="학습 코스" Style="{StaticResource ScreenTitleText}" />
                    <TextBlock Text="COURSES" Style="{StaticResource MonoMutedText}" Margin="8,0,0,0" VerticalAlignment="Center"
                               Visibility="{Binding Shell.EnglishOn, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                    <ProgressBar Style="{StaticResource AccentProgress}" Height="5" Width="140"
                                 Value="{Binding Shell.OverallPct, Mode=OneWay}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Shell.ProgressText}" FontFamily="{StaticResource MonoFont}" FontSize="11"
                               Foreground="{StaticResource BodyBrush}" Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="4" Style="{StaticResource DarkButton}" Content="자유 모드"
                        Command="{Binding GoStudioFreeCommand}" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Course cards -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Courses}" MaxWidth="880" Margin="24,28,24,56">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CourseRowViewModel}">
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderCardBrush}" BorderThickness="1"
                                CornerRadius="14" Padding="22,20" Margin="0,0,0,18">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource AccentTintBrush}" CornerRadius="7" Padding="8,4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Num}" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="16.5" FontWeight="Bold" />
                                        <TextBlock Text="{Binding English}" FontFamily="{StaticResource MonoFont}" FontSize="10.5"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding English}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ProgressLabel}" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                   Foreground="{StaticResource BodyBrush}" HorizontalAlignment="Right" />
                                        <ProgressBar Style="{StaticResource AccentProgress}" Height="5" Width="120"
                                                     Background="{StaticResource TrackSoftBrush}"
                                                     Value="{Binding Pct, Mode=OneWay}" Margin="0,5,0,0" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding Description}" FontSize="13" Foreground="{StaticResource BodyBrush}"
                                           TextWrapping="Wrap" LineHeight="20.8" LineStackingStrategy="BlockLineHeight"
                                           Margin="0,13,0,0" />
                                <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,1,0,0" Margin="0,13,0,0">
                                    <ItemsControl ItemsSource="{Binding Lessons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:LessonRowViewModel}">
                                                <Button Command="{Binding StartCommand}" Cursor="Hand" Focusable="False" AutomationProperties.Name="{Binding Title}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Row" Background="Transparent" CornerRadius="8"
                                                                    BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1"
                                                                    Padding="6,11">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid Width="24" Height="24" VerticalAlignment="Center">
                                                                        <Ellipse x:Name="StCircle" Fill="{StaticResource SurfaceBrush}"
                                                                                 Stroke="{StaticResource KnobBrush}" StrokeThickness="1.5" />
                                                                        <TextBlock x:Name="StGlyph" Text="{Binding Glyph}" FontSize="12" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource MutedBrush}"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Grid>
                                                                    <Border x:Name="KindBadge" Grid.Column="1" CornerRadius="6" Padding="8,3"
                                                                            Background="{StaticResource LessonTintBrush}" Margin="12,0,0,0"
                                                                            VerticalAlignment="Center">
                                                                        <TextBlock x:Name="KindText" Text="{Binding KindLabel}" FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource BodyBrush}" />
                                                                    </Border>
                                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="Medium" />
                                                                        <TextBlock Text="{Binding English}" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                                                                   Foreground="{StaticResource MutedBrush}" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding English}" Value="">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="3" Text="{Binding Minutes}" FontFamily="{StaticResource MonoFont}"
                                                                               FontSize="11" Foreground="{StaticResource MutedBrush}"
                                                                               Margin="12,0,0,0" VerticalAlignment="Center" />
                                                                    <TextBlock x:Name="Cta" Grid.Column="4" Text="{Binding Cta}" FontSize="12" FontWeight="SemiBold"
                                                                               Foreground="{StaticResource AccentBrush}" Margin="12,0,0,0" VerticalAlignment="Center" />
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Row" Property="Background" Value="{StaticResource HeaderBrush}" />
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                    <Setter TargetName="StCircle" Property="Fill" Value="{StaticResource GreenBrush}" />
                                                                    <Setter TargetName="StCircle" Property="Stroke" Value="{StaticResource GreenBrush}" />
                                                                    <Setter TargetName="StGlyph" Property="Foreground" Value="{StaticResource SurfaceBrush}" />
                                                                    <Setter TargetName="Cta" Property="Foreground" Value="{StaticResource MutedBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding KindLabel}" Value="미션">
                                                                    <Setter TargetName="KindBadge" Property="Background" Value="{StaticResource MissionTintBrush}" />
                                                                    <Setter TargetName="KindText" Property="Foreground" Value="{StaticResource MissionFgBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding KindLabel}" Value="퀴즈">
                                                                    <Setter TargetName="KindBadge" Property="Background" Value="{StaticResource GreenTintBrush}" />
                                                                    <Setter TargetName="KindText" Property="Foreground" Value="{StaticResource GreenBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding KindLabel}" Value="이론">
                                                                    <Setter TargetName="KindBadge" Property="Background" Value="{StaticResource IndigoTintBrush}" />
                                                                    <Setter TargetName="KindText" Property="Foreground" Value="{StaticResource IndigoBrush}" />
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Quiz modal -->
        <Grid Grid.RowSpan="2" Background="{StaticResource OverlayBrush}"
              Visibility="{Binding ActiveQuiz, Converter={StaticResource NotNullToVisibility}}">
            <Border Width="520" MaxWidth="700" Background="{StaticResource SurfaceBrush}" CornerRadius="16" Padding="24,22"
                    HorizontalAlignment="Center" VerticalAlignment="Center" DataContext="{Binding ActiveQuiz}">
                <Border.Effect>
                    <DropShadowEffect Color="{StaticResource ShadowColor}" Opacity="0.4" BlurRadius="64" ShadowDepth="24" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource GreenTintBrush}" CornerRadius="6" Padding="8,3" VerticalAlignment="Center">
                            <TextBlock Text="퀴즈" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource GreenBrush}" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="15" FontWeight="Bold" Margin="10,0" VerticalAlignment="Center" />
                        <Button Grid.Column="2" Style="{StaticResource CloseButton}" Command="{Binding CloseCommand}" AutomationProperties.Name="퀴즈 닫기" />
                    </Grid>

                    <!-- Active question -->
                    <StackPanel Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding Counter}" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,15,0,0" />
                        <TextBlock Text="{Binding QuestionText}" FontSize="17" FontWeight="Bold" TextWrapping="Wrap"
                                   LineHeight="25.5" LineStackingStrategy="BlockLineHeight" Margin="0,15,0,0" />
                        <ItemsControl ItemsSource="{Binding Options}" Margin="0,15,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:QuizOptionViewModel}">
                                    <Button Command="{Binding PickCommand}" Cursor="Hand" Focusable="False" Margin="0,0,0,8" AutomationProperties.Name="{Binding Label}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Chrome" Background="{StaticResource SurfaceBrush}"
                                                        BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1.5"
                                                        CornerRadius="10" Padding="14,11">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Letter}" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                                   FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="14" Margin="10,0,0,0"
                                                                   TextWrapping="Wrap" VerticalAlignment="Center" />
                                                        <TextBlock x:Name="Mark" Grid.Column="2" Text="{Binding Mark}" FontSize="13" FontWeight="Bold"
                                                                   Foreground="{StaticResource GreenBrush}" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="Correct">
                                                        <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource GreenBrush}" />
                                                        <Setter TargetName="Chrome" Property="Background" Value="{StaticResource GreenTintBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="WrongPick">
                                                        <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                                        <Setter TargetName="Chrome" Property="Background" Value="{StaticResource WrongTintBrush}" />
                                                        <Setter TargetName="Mark" Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="Dimmed">
                                                        <Setter TargetName="Chrome" Property="Opacity" Value="0.55" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Visibility="{Binding Revealed, Converter={StaticResource BoolToVisibility}}">
                            <Border Background="{StaticResource HeaderBrush}" BorderBrush="{StaticResource BorderSoftBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,7,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Feedback}" FontSize="13.5" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource GreenBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FeedbackIsCorrect}" Value="False">
                                                        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Why}" FontSize="12.5" Foreground="{StaticResource BodyBrush}"
                                               TextWrapping="Wrap" LineHeight="19.4" LineStackingStrategy="BlockLineHeight" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Button Style="{StaticResource DarkButton}" Content="{Binding NextLabel}" Command="{Binding NextCommand}"
                                    Padding="18,9" FontSize="13" HorizontalAlignment="Right" Margin="0,15,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Score -->
                    <StackPanel Visibility="{Binding Finished, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding Score}" FontFamily="{StaticResource MonoFont}" FontSize="32" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Margin="0,23,0,0" />
                        <TextBlock Text="{Binding ResultMessage}" FontSize="14" Foreground="{StaticResource BodyBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,4">
                            <Button Style="{StaticResource GhostButton}" Content="다시 풀기" Command="{Binding RetryCommand}" Padding="18,9" />
                            <Button Style="{StaticResource AccentButton}" Content="완료" Command="{Binding CloseCommand}" Padding="18,9" Margin="10,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Reading modal -->
        <Grid Grid.RowSpan="2" Background="{StaticResource OverlayBrush}"
              Visibility="{Binding ActiveReading, Converter={StaticResource NotNullToVisibility}}">
            <Border Width="620" MaxHeight="740" Background="{StaticResource SurfaceBrush}" CornerRadius="16" Padding="24,22"
                    HorizontalAlignment="Center" VerticalAlignment="Center" DataContext="{Binding ActiveReading}">
                <Border.Effect>
                    <DropShadowEffect Color="{StaticResource ShadowColor}" Opacity="0.4" BlurRadius="64" ShadowDepth="24" Direction="270" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource IndigoTintBrush}" CornerRadius="6" Padding="8,3" VerticalAlignment="Center">
                            <TextBlock Text="이론" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource IndigoBrush}" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="15" FontWeight="Bold" Margin="10,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding PageLabel}" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                        <Button Grid.Column="3" Style="{StaticResource CloseButton}" Command="{Binding CloseCommand}" AutomationProperties.Name="이론 닫기" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding PageTitle}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"
                                       LineHeight="25.2" LineStackingStrategy="BlockLineHeight" />
                            <ItemsControl ItemsSource="{Binding Paragraphs}" Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="13.5" Foreground="{StaticResource InkSoftBrush}"
                                                   TextWrapping="Wrap" LineHeight="23" LineStackingStrategy="BlockLineHeight"
                                                   Margin="0,0,0,10" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border Background="{StaticResource DarkBarBrush}" CornerRadius="10" Padding="16,14" Margin="0,4,0,0"
                                    Visibility="{Binding HasCode, Converter={StaticResource BoolToVisibility}}">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <TextBlock Text="{Binding Code}" FontFamily="{StaticResource MonoFont}" FontSize="11.5"
                                               Foreground="{StaticResource DarkSoftFgBrush}" LineHeight="18.4" LineStackingStrategy="BlockLineHeight" />
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Content="← 이전" Command="{Binding PrevCommand}" Padding="16,9">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PrevEnabled}" Value="False">
                                            <Setter Property="Opacity" Value="0.35" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource AccentButton}" Content="{Binding NextLabel}"
                                Command="{Binding NextCommand}" Padding="18,9" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
