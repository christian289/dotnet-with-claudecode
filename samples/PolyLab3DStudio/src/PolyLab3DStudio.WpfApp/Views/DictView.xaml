<UserControl x:Class="PolyLab3DStudio.Views.DictView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PaperBrush}">
    <UserControl.Resources>

        <!-- Category filter chip (pill; selected = dark). -->
        <DataTemplate x:Key="DictCategoryChipTemplate">
            <Button Command="{Binding SelectCommand}" Cursor="Hand" Focusable="False"
                    AutomationProperties.Name="{Binding Label}" Margin="0,0,6,6">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderStrongBrush}"
                                BorderThickness="1" CornerRadius="16" Padding="12,6">
                            <TextBlock x:Name="Label" Text="{Binding Label}" FontSize="12"
                                       FontWeight="SemiBold" Foreground="{StaticResource BodyBrush}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource InkBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource InkBrush}" />
                                <Setter TargetName="Label" Property="Foreground" Value="{StaticResource SurfaceBrush}" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- One glossary term card. -->
        <DataTemplate x:Key="DictTermCardTemplate">
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderCardBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="16,14"
                    Margin="0,0,10,10"
                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=WrapPanel}, Converter={StaticResource HalfWidth}, ConverterParameter=21}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock>
                            <Run Text="{Binding Word, Mode=OneWay}" FontSize="14.5" FontWeight="Bold"
                                 Foreground="{StaticResource InkBrush}" /><Run Text=" " /><Run
                                 Text="{Binding English, Mode=OneWay}"
                                 FontFamily="{StaticResource MonoFont}" FontSize="10.5"
                                 Foreground="{StaticResource MutedBrush}" />
                        </TextBlock>
                        <Border Grid.Column="2" Background="{StaticResource DividerBrush}"
                                CornerRadius="5" Padding="7,2" VerticalAlignment="Top" Margin="8,1,0,0">
                            <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource BodyBrush}" />
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding Short}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}" TextWrapping="Wrap"
                               LineHeight="20.8" LineStackingStrategy="BlockLineHeight"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding Detail}" FontSize="12.5"
                               Foreground="{StaticResource BodyBrush}" TextWrapping="Wrap"
                               LineHeight="20.6" LineStackingStrategy="BlockLineHeight"
                               Margin="0,6,0,0" />
                    <TextBlock FontSize="11.5" Margin="0,7,0,0"
                               Visibility="{Binding DocUrl, Converter={StaticResource NotNullToVisibility}}">
                        <Hyperlink Click="OnDocLinkClick"
                                   Tag="{Binding DocUrl}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   TextDecorations="{x:Null}"
                                   Cursor="Hand">Microsoft Learn 문서 ↗</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <DockPanel>

        <!-- Sticky header: title row + search/chip rows -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource HeaderBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <Grid Height="60" Margin="28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Style="{StaticResource BackButton}" Command="{Binding GoStartCommand}"
                            AutomationProperties.Name="사전 뒤로" VerticalAlignment="Center" />
                    <ContentControl Grid.Column="1"
                                    ContentTemplate="{StaticResource LogoIconTemplate}"
                                    Content=""
                                    Focusable="False"
                                    VerticalAlignment="Center"
                                    Margin="14,0,0,0" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="3D 사전" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Style="{StaticResource TaglineMonoText}"
                                   Text="3D GLOSSARY"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBlock Grid.Column="4" Text="{Binding CountText}"
                               FontFamily="{StaticResource MonoFont}" FontSize="11"
                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                </Grid>
                <StackPanel Margin="28,0,28,14">
                    <Grid Width="520" HorizontalAlignment="Left">
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderStrongBrush}"
                                BorderThickness="1" CornerRadius="10" />
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="14" Foreground="{StaticResource InkBrush}"
                                 Padding="14,11"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="용어 검색" />
                        <TextBlock Text="용어 검색… (한글·영어 모두 가능)"
                                   FontSize="14" Foreground="{StaticResource MutedBrush}"
                                   Margin="18,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Categories}"
                                  ItemTemplate="{StaticResource DictCategoryChipTemplate}"
                                  Focusable="False"
                                  Margin="0,10,0,-6">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      PanningMode="VerticalOnly">
            <StackPanel MaxWidth="960" Margin="24,24,24,64">
                <TextBlock Text="검색 결과가 없어요. 다른 말로 검색해 보세요."
                           FontSize="14" Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center" Margin="0,48"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" />
                <ItemsControl ItemsSource="{Binding Terms}"
                              ItemTemplate="{StaticResource DictTermCardTemplate}"
                              Focusable="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
