<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Guide screen typography (ported from the concept guide app). -->

    <Style x:Key="H1Text" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="43" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    </Style>

    <Style x:Key="H2Text" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    </Style>

    <Style x:Key="SectionNumberText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style x:Key="TaglineMonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
    </Style>

    <Style x:Key="SubLabelText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="LeadText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource BodyBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="25.5" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    </Style>

    <Style x:Key="BulletText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20.8" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    </Style>

    <Style x:Key="CalloutText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="Foreground" Value="{StaticResource BodyBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
    </Style>

    <Style x:Key="CalloutLabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="9.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Margin" Value="0,2,8,0" />
    </Style>

    <Style x:Key="FootnoteText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,8,0,0" />
    </Style>

    <!-- Glossary term-tip: dotted accent underline + hover tooltip (design's term-tip). -->

    <TextDecorationCollection x:Key="TermTipUnderline">
        <TextDecoration Location="Underline" PenOffset="2" PenOffsetUnit="Pixel">
            <TextDecoration.Pen>
                <Pen Brush="{StaticResource AccentBrush}" Thickness="1.5" DashCap="Round">
                    <Pen.DashStyle>
                        <DashStyle Dashes="0,2.2" />
                    </Pen.DashStyle>
                </Pen>
            </TextDecoration.Pen>
        </TextDecoration>
    </TextDecorationCollection>

    <!-- Dark styled tooltip card used by the TermTip inline control. -->
    <Style x:Key="TermTipToolTip" TargetType="ToolTip">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{StaticResource DarkCardBrush}"
                            CornerRadius="12"
                            Padding="15,13"
                            MaxWidth="320"
                            Margin="4,4,18,22">
                        <Border.Effect>
                            <DropShadowEffect Color="#141C26" Opacity="0.45" BlurRadius="36"
                                              ShadowDepth="14" Direction="270" />
                        </Border.Effect>
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Guide screen containers and chips. -->

    <Style x:Key="GuideCardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderCardBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
    </Style>

    <Style x:Key="CalloutBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,11" />
    </Style>

    <Style x:Key="TintCalloutBorder" TargetType="Border" BasedOn="{StaticResource CalloutBorder}">
        <Setter Property="Background" Value="{StaticResource AccentTintBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentTintBorderBrush}" />
    </Style>

    <Style x:Key="CardDivider" TargetType="Rectangle">
        <Setter Property="Height" Value="1" />
        <Setter Property="Fill" Value="{StaticResource DividerBrush}" />
        <Setter Property="Margin" Value="0,14" />
    </Style>

    <Style x:Key="WorkflowChip" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HeaderBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style x:Key="ShortcutChipBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HeaderBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="10,5" />
    </Style>

    <Style x:Key="MiniCardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HeaderBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14,12" />
    </Style>

</ResourceDictionary>
