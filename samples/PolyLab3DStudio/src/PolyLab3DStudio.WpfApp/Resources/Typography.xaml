<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- IBM Plex when installed; per-glyph fallback otherwise. -->
    <FontFamily x:Key="BodyFont">IBM Plex Sans KR, Segoe UI, Malgun Gothic</FontFamily>
    <FontFamily x:Key="MonoFont">IBM Plex Mono, Cascadia Mono, Consolas</FontFamily>

    <Style x:Key="MonoMutedText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Setter Property="FontSize" Value="10.5" />
    </Style>

    <Style x:Key="PanelLabelText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
    </Style>

    <Style x:Key="ScreenTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    </Style>

</ResourceDictionary>
