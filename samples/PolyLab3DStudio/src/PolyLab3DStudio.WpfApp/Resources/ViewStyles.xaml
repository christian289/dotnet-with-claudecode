<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Per-screen named styles, centralized here (merged from App.xaml) so
         every size/color decision lives in the theme dictionaries. Structural
         DataTemplates stay in their views; only reusable look-and-feel styles
         belong here. -->

    <!-- ============ StartView ============ -->

    <!-- Dark reference card: Content = title, Tag = subtitle. -->
    <Style x:Key="ReferenceCard" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome" Background="{StaticResource DarkBarBrush}"
                            CornerRadius="11" Padding="14,12" Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="{TemplateBinding Content}" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource SurfaceBrush}" />
                            <TextBlock Text="{TemplateBinding Tag}" FontSize="11"
                                       Foreground="{StaticResource SurfaceBrush}" Opacity="0.72"
                                       TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource DarkBarHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ StudioView ============ -->

    <!-- Group caption under each ribbon cluster. -->
    <Style x:Key="RibbonCaption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,3,0,0" />
    </Style>

    <Style x:Key="RibbonDividerLine" TargetType="Rectangle">
        <Setter Property="Width" Value="1" />
        <Setter Property="Fill" Value="{StaticResource RibbonDividerBrush}" />
        <Setter Property="Margin" Value="4" />
    </Style>

    <!-- Viewport preset pill. -->
    <Style x:Key="PresetButton" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome" Background="{StaticResource ViewportPillBrush}" CornerRadius="7" Padding="11,6">
                        <TextBlock Text="{TemplateBinding Content}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource DarkSoftFgBrush}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ViewportPillHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Properties/light slider row label pair. -->
    <Style x:Key="SliderCaption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource BodyBrush}" />
    </Style>

    <Style x:Key="SliderValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    </Style>

    <!-- ============ ToolMapView ============ -->

    <!-- Ladder step card -->
    <Style x:Key="LadderStepBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HeaderBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Padding" Value="14,12" />
    </Style>

    <Style x:Key="LadderOrdinalText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style x:Key="LadderTitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Margin" Value="0,3,0,0" />
    </Style>

    <Style x:Key="LadderDescText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="16.5" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="Margin" Value="0,3,0,0" />
    </Style>

    <Style x:Key="LadderArrowText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource FaintBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="8,0" />
    </Style>

    <!-- Comparison table cells -->
    <Style x:Key="TableToolHeaderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Margin" Value="14,12" />
    </Style>

    <Style x:Key="TableValueText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Foreground" Value="{StaticResource InkSoftBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="17.8" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="Margin" Value="14,11" />
    </Style>

    <Style x:Key="TableCellBorder" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1,0,0,0" />
    </Style>

</ResourceDictionary>
