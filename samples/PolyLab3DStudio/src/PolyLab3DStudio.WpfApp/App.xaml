<Application x:Class="PolyLab3DStudio.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PolyLab3DStudio.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Palette.xaml" />
                <ResourceDictionary Source="Resources/Typography.xaml" />
                <ResourceDictionary Source="Resources/Controls.xaml" />
                <ResourceDictionary Source="Resources/GuideStyles.xaml" />
                <ResourceDictionary Source="Resources/GuideIcons.xaml" />
                <ResourceDictionary Source="Resources/GuideTemplates.xaml" />
                <ResourceDictionary Source="Resources/Mappings.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:HexToBrushConverter x:Key="HexToBrush" />
            <conv:StringToGeometryConverter x:Key="StringToGeometry" />
            <conv:ValuesEqualConverter x:Key="ValuesEqual" />
            <conv:NotNullToVisibilityConverter x:Key="NotNullToVisibility" />
            <conv:EnglishLabelConverter x:Key="EnglishLabel" />
            <conv:HalfWidthConverter x:Key="HalfWidth" />
            <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
