<Window
    x:Class="ClaudeDesk.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="{Binding Title}"
    Width="800"
    Height="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="8"
            Orientation="Horizontal">
            <Button
                Margin="0,0,6,0"
                Padding="10,4"
                AutomationProperties.AutomationId="NavChatButton"
                Command="{Binding NavigateToChatCommand}"
                Content="Chat" />
            <Button
                Padding="10,4"
                AutomationProperties.AutomationId="NavSettingsButton"
                Command="{Binding NavigateToSettingsCommand}"
                Content="Settings" />
        </StackPanel>

        <!--  CurrentViewModel is resolved to its View by Mappings.xaml (ViewModel First).  -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
