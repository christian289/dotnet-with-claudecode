<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:ClaudeDesk.Views"
    xmlns:vm="clr-namespace:ClaudeDesk.ViewModels;assembly=ClaudeDesk.ViewModels">

    <!--  /wpf-dev-pack:make-wpf-viewmodel appends one entry per screen.  -->

    <DataTemplate DataType="{x:Type vm:ChatViewModel}">
        <views:ChatView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
        <views:SettingsView />
    </DataTemplate>

</ResourceDictionary>
