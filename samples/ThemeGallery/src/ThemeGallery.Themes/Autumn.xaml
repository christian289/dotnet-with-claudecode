                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============================================================  -->
    <!--  13. Slider — branch track, conker thumb  -->
    <!--  ============================================================  -->
    <Style TargetType="{x:Type Slider}">
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource AutumnFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid
                        x:Name="Root"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                        <!--  Branch losing leaves  -->
                        <Border
                            Height="6"
                            VerticalAlignment="Center"
                            BorderBrush="#3E2410"
                            BorderThickness="1"
                            CornerRadius="3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="#6B3E1D" />
                                    <GradientStop Offset="1" Color="#4A2511" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Rectangle
                            Height="8"
                            Margin="4,0"
                            VerticalAlignment="Center"
                            Fill="{StaticResource AutumnFleckBrush}"
                            IsHitTestVisible="False"
                            Opacity="0.75" />
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{StaticResource AutumnTransparentRepeat}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{StaticResource AutumnTransparentRepeat}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource AutumnConkerThumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============================================================  -->
    <!--  14. ProgressBar — leaf-pile fill + tumbling-leaf ambient  -->
    <!--  ============================================================  -->
    <Style TargetType="{x:Type ProgressBar}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Grid
                        x:Name="Root"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                        <Border
                            x:Name="PART_Track"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#8A5A2B" />
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="#3D1F0E" />
                            </Border.Background>
                        </Border>
                        <!--  Accumulating leaf pile  -->
                        <Border
                            x:Name="PART_Indicator"
                            HorizontalAlignment="Left"
                            ClipToBounds="True"
                            CornerRadius="8">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#8E2C1E" />
                                    <GradientStop Offset="0.45" Color="#C0392B" />
                                    <GradientStop Offset="0.75" Color="#D2691E" />
                                    <GradientStop Offset="1" Color="#E5A33B" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <!--  Ambient: drifting sheen across the pile  -->
                            <Rectangle
                                x:Name="PileSheen"
                                Width="46"
                                HorizontalAlignment="Left"
                                IsHitTestVisible="False"
                                Opacity="0.4">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0" Color="#00F5E9D3" />
                                        <GradientStop Offset="0.5" Color="#7DF5E9D3" />
                                        <GradientStop Offset="1" Color="#00F5E9D3" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                                <Rectangle.RenderTransform>
                                    <TranslateTransform X="-50" />
                                </Rectangle.RenderTransform>
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Rectangle.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    RepeatBehavior="Forever"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                    From="-50"
                                                    To="360"
                                                    Duration="0:0:2.6" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                        </Border>
                        <!--  Signature ambient: single leaf tumbling end to end  -->
                        <Path
                            x:Name="TumbleLeaf"
                            Width="14"
                            Height="14"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Data="{StaticResource AutumnLeafGeometry}"
                            Fill="#E5A33B"
                            IsHitTestVisible="False"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5"
                            Stretch="Uniform">
                            <Path.RenderTransform>
                                <TransformGroup>
                                    <RotateTransform x:Name="LeafSpin" Angle="0" />
                                    <TranslateTransform x:Name="LeafDrift" X="-18" />
                                </TransformGroup>
                            </Path.RenderTransform>
                        </Path>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed" />
                            <Trigger.EnterActions>
                                <BeginStoryboard Name="TumbleSb">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="TumbleLeaf"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="LeafDrift"
                                            Storyboard.TargetProperty="X"
                                            From="-18"
                                            To="330"
                                            Duration="0:0:2.8">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="LeafSpin"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:1.4" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="TumbleSb" />
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============================================================  -->
    <!--  15. ScrollBar — branch segment thumb, both orientations  -->
    <!--  ============================================================  -->
    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Width" Value="12" />
        <Setter Property="Background" Value="Transparent" />
