<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Diablo theme: dark-gothic ARPG. Obsidian slabs, ember glow, blood vignette.
        Self-contained per THEME-CONTRACT.md. Animated brushes are always inline.
        Signature ambient animations: molten highlight sweeping the ProgressBar fill
        (Loaded, Forever) and the flickering brazier ember in the Expander header.
    -->

    <!--  Palette  -->
    <Color x:Key="ColBone">#E6D6AE</Color>
    <Color x:Key="ColBoneDim">#A08C66</Color>
    <Color x:Key="ColEmber">#FF7A29</Color>
    <Color x:Key="ColEmberBright">#FFB259</Color>
    <Color x:Key="ColEmberDim">#B34A10</Color>
    <Color x:Key="ColBlood">#8C1A12</Color>
    <Color x:Key="ColIron">#221C18</Color>
    <Color x:Key="ColIronDark">#15100D</Color>
    <Color x:Key="ColSocket">#0C0807</Color>
    <Color x:Key="ColBronze">#5A4128</Color>

    <!--  Shell brush keys (contract section 1.3)  -->
    <RadialGradientBrush x:Key="ThemeWindowBackgroundBrush" Center="0.5,0.42" GradientOrigin="0.5,0.42" RadiusX="0.95" RadiusY="0.9">
        <GradientStop Offset="0" Color="#171009" />
        <GradientStop Offset="0.55" Color="#100808" />
        <GradientStop Offset="0.85" Color="#260909" />
        <GradientStop Offset="1" Color="#330B0A" />
    </RadialGradientBrush>
    <SolidColorBrush x:Key="ThemeTextBrush" Color="{StaticResource ColBone}" />
    <SolidColorBrush x:Key="ThemeSubtleTextBrush" Color="{StaticResource ColBoneDim}" />
    <SolidColorBrush x:Key="ThemeAccentBrush" Color="{StaticResource ColEmber}" />
    <LinearGradientBrush x:Key="ThemeCardBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#1C1410" />
        <GradientStop Offset="1" Color="#120C0A" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ThemeBorderBrush" Color="{StaticResource ColBronze}" />

    <!--  Shared static brushes (never animated; animated brushes are inline)  -->
    <SolidColorBrush x:Key="DiabloBoneBrush" Color="{StaticResource ColBone}" />
    <SolidColorBrush x:Key="DiabloBoneDimBrush" Color="{StaticResource ColBoneDim}" />
    <SolidColorBrush x:Key="DiabloEmberBrush" Color="{StaticResource ColEmber}" />
    <SolidColorBrush x:Key="DiabloSocketBrush" Color="{StaticResource ColSocket}" />
    <SolidColorBrush x:Key="DiabloBronzeBrush" Color="{StaticResource ColBronze}" />
    <LinearGradientBrush x:Key="DiabloSlabBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#362C25" />
        <GradientStop Offset="0.5" Color="#221A15" />
        <GradientStop Offset="1" Color="#120D0B" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DiabloBevelBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#6B5436" />
        <GradientStop Offset="0.5" Color="#3C2C1D" />
        <GradientStop Offset="1" Color="#0A0706" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DiabloGrimoireBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#241A12" />
        <GradientStop Offset="0.12" Color="#1B130D" />
        <GradientStop Offset="1" Color="#120C09" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DiabloGrooveBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#050303" />
        <GradientStop Offset="1" Color="#1A0E0B" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DiabloIronBarBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#3A2E24" />
        <GradientStop Offset="0.5" Color="#1B1310" />
        <GradientStop Offset="1" Color="#0C0807" />
    </LinearGradientBrush>

    <!--  Keyboard focus cue  -->
    <Style x:Key="DiabloFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle
                        Margin="-3"
                        RadiusX="2"
                        RadiusY="2"
                        SnapsToDevicePixels="True"
                        Stroke="{StaticResource DiabloEmberBrush}"
                        StrokeDashArray="1 2"
                        StrokeThickness="1" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Transparent repeat buttons for Slider / ScrollBar tracks  -->
    <Style x:Key="DiabloTrackRepeatButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ScrollBar line (arrow) buttons  -->
    <Style x:Key="DiabloScrollLineButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border
                        x:Name="Bd"
                        Padding="3"
                        SnapsToDevicePixels="True">
                        <Border.Background>
                            <SolidColorBrush Color="#00FF7A29" />
                        </Border.Background>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#33FF7A29"
                                            Duration="0:0:0.15">
                                            <ColorAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#00FF7A29"
                                            Duration="0:0:0.2">
                                            <ColorAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#59FF7A29"
                                            Duration="0:0:0.12">
                                            <ColorAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#00FF7A29"
                                            Duration="0:0:0.2">
                                            <ColorAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Wrought-iron spiked ScrollBar thumb  -->
    <Style x:Key="DiabloScrollThumb" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid SnapsToDevicePixels="True">
                        <Border
                            x:Name="Bar"
                            Margin="2"
                            Background="{StaticResource DiabloIronBarBrush}"
                            BorderBrush="#050403"
                            BorderThickness="1"
                            CornerRadius="4" />
                        <Path
                            x:Name="Spike"
                            Width="8"
                            Height="8"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="M 4,0 L 8,4 4,8 0,4 Z"
                            Stretch="Fill">
                            <Path.Fill>
                                <SolidColorBrush Color="#B34A10" />
                            </Path.Fill>
                        </Path>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Spike"
                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                            To="#FF7A29"
                                            Duration="0:0:0.15">
                                            <ColorAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Spike"
                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                            To="#B34A10"
                                            Duration="0:0:0.25">
                                            <ColorAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Spike"
                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                            To="#FFC07A"
                                            Duration="0:0:0.12">
                                            <ColorAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Spike"
                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                            To="#B34A10"
                                            Duration="0:0:0.25">
                                            <ColorAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Ember gem Slider thumb: flares on hover, blazes while dragging  -->
    <Style x:Key="DiabloSliderThumb" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid x:Name="GemRoot" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Path
                            x:Name="Gem"
                            Data="M 7,0 L 14,9 7,18 0,9 Z"
                            Stretch="Fill"
                            Stroke="#050403"
                            StrokeThickness="1">
                            <Path.Fill>
                                <RadialGradientBrush>
                                    <GradientStop x:Name="GemCore" Offset="0.15" Color="#FFB259" />
                                    <GradientStop Offset="0.7" Color="#B33A0F" />
                                    <GradientStop Offset="1" Color="#5A1408" />
                                </RadialGradientBrush>
                            </Path.Fill>
                            <Path.Effect>
                                <DropShadowEffect
                                    BlurRadius="10"
                                    Opacity="0.25"
                                    ShadowDepth="0"
                                    Color="#FF7A29" />
                            </Path.Effect>
                        </Path>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Gem"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.9"
                                            Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation
                                            Storyboard.TargetName="Gem"
                                            Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)"
                                            To="#FFE0A0"
                                            Duration="0:0:0.18">
                                            <ColorAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Gem"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.25"
                                            Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation
                                            Storyboard.TargetName="Gem"
                                            Storyboard.TargetProperty="(Shape.Fill).(GradientBrush.GradientStops)[0].(GradientStop.Color)"
                                            To="#FFB259"
                                            Duration="0:0:0.3">
                                            <ColorAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="GemRoot"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                            To="1.18"
                                            Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.5" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="GemRoot"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                            To="1.18"
                                            Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.5" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Gem"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="1"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="GemRoot"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                            To="1"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="GemRoot"
                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                            To="1"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Gem"
                                            Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                            To="0.25"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ Button: obsidian slab, ember glow pulses on hover, sinks on press ============  -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource DiabloBoneBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="20,9" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource DiabloFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="SlabScale" />
                        </Grid.RenderTransform>
                        <Border
                            x:Name="Slab"
                            Background="{StaticResource DiabloSlabBrush}"
                            BorderBrush="{StaticResource DiabloBevelBrush}"
                            BorderThickness="1.5"
                            CornerRadius="3">
                            <Grid>
                                <Border x:Name="Ember" CornerRadius="2">
                                    <Border.Background>
                                        <RadialGradientBrush Center="0.5,1" GradientOrigin="0.5,1" RadiusX="0.8" RadiusY="1">
                                            <GradientStop x:Name="EmberStop" Offset="0" Color="#00FF7A29" />
                                            <GradientStop Offset="1" Color="#00FF7A29" />
                                        </RadialGradientBrush>
                                    </Border.Background>
                                </Border>
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="EmberPulseBSB">
                                    <Storyboard>
                                        <ColorAnimation
                                            AutoReverse="True"
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="EmberStop"
                                            Storyboard.TargetProperty="Color"
                                            To="#B3FF7A29"
                                            Duration="0:0:0.9">
                                            <ColorAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="EmberPulseBSB" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="EmberStop"
                                            Storyboard.TargetProperty="Color"
                                            To="#00FF7A29"
                                            Duration="0:0:0.4" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="SlabScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.96"
                                            Duration="0:0:0.1" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="SlabScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.92"
                                            Duration="0:0:0.1" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Slab"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.8"
                                            Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="SlabScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.18" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="SlabScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.18" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Slab"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Slab" Property="Opacity" Value="0.4" />
                            <Setter Property="Foreground" Value="{StaticResource DiabloBoneDimBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ ToggleButton: a brazier that lights when on ============  -->
    <Style TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{StaticResource DiabloBoneBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource DiabloFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border
                        x:Name="Bd"
                        Background="{StaticResource DiabloSlabBrush}"
                        BorderThickness="1.5"
                        CornerRadius="3">
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="BdEdge" Color="#5A4128" />
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect
                                x:Name="Glow"
                                BlurRadius="0"
                                Opacity="0"
                                ShadowDepth="0"
                                Color="#FF7A29" />
                        </Border.Effect>
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="BdEdge"
                                            Storyboard.TargetProperty="Color"
                                            To="#FF7A29"
                                            Duration="0:0:0.3" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glow"
                                            Storyboard.TargetProperty="(DropShadowEffect.BlurRadius)"
                                            To="16"
                                            Duration="0:0:0.3" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glow"
                                            Storyboard.TargetProperty="(DropShadowEffect.Opacity)"
                                            To="0.85"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="BdEdge"
                                            Storyboard.TargetProperty="Color"
                                            Duration="0:0:0.3" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glow"
                                            Storyboard.TargetProperty="(DropShadowEffect.BlurRadius)"
                                            To="0"
                                            Duration="0:0:0.3" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glow"
                                            Storyboard.TargetProperty="(DropShadowEffect.Opacity)"
                                            To="0"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ CheckBox: a rune ignites in a cold socket ============  -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource DiabloBoneBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource DiabloFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <StackPanel Background="Transparent" Orientation="Horizontal">
                        <Border
                            Width="22"
                            Height="22"
                            VerticalAlignment="Center"
                            Background="{StaticResource DiabloSocketBrush}"
                            BorderBrush="{StaticResource DiabloBronzeBrush}"
                            BorderThickness="1.5"
                            CornerRadius="2">
                            <Path
                                x:Name="Rune"
                                Margin="3"
                                Data="M8,0 L10,5 L16,5 L11,9 L13,16 L8,12 L3,16 L5,9 L0,5 L6,5 Z"
                                Fill="{StaticResource DiabloEmberBrush}"
                                RenderTransformOrigin="0.5,0.5"
                                Stretch="Uniform">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="RuneScale" ScaleX="0" ScaleY="0" />
                                </Path.RenderTransform>
                                <Path.Effect>
                                    <DropShadowEffect
                                        x:Name="RuneGlow"
                                        BlurRadius="8"
                                        Opacity="0"
                                        ShadowDepth="0"
                                        Color="#FF7A29" />
                                </Path.Effect>
                            </Path>
                        </Border>
                        <ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RuneScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.35">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.5" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RuneScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.35">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.5" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RuneGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.Opacity)"
                                            To="0.9"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RuneScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RuneScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RuneGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.Opacity)"
                                            To="0"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ RadioButton: a demonic eye, iris glows and pulses when selected ============  -->
    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{StaticResource DiabloBoneBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource DiabloFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <StackPanel Background="Transparent" Orientation="Horizontal">
                        <Grid
                            Width="22"
                            Height="22"
                            VerticalAlignment="Center">
                            <Ellipse
                                Fill="{StaticResource DiabloSocketBrush}"
                                Stroke="{StaticResource DiabloBronzeBrush}"
                                StrokeThickness="1.5" />
                            <Ellipse
                                x:Name="Iris"
                                Width="11"
                                Height="11"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Offset="0" Color="#FFB259" />
                                        <GradientStop Offset="0.6" Color="#C8260C" />
                                        <GradientStop Offset="1" Color="#5A0A06" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="IrisScale" ScaleX="0" ScaleY="0" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect
                                        x:Name="IrisGlow"
                                        BlurRadius="9"
                                        Opacity="0"
                                        ShadowDepth="0"
                                        Color="#FF2A0A" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="EyeBSB">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="IrisScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.4" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="IrisScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.4" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            AutoReverse="True"
                                            BeginTime="0:0:0.3"
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="IrisGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.BlurRadius)"
                                            To="18"
                                            Duration="0:0:1" />
                                        <DoubleAnimation
                                            BeginTime="0:0:0.3"
                                            Storyboard.TargetName="IrisGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.Opacity)"
                                            To="0.95"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="EyeBSB" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="IrisScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="IrisScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="IrisGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.Opacity)"
                                            To="0"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ TextBox: ember border ignition on focus ============  -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{StaticResource DiabloBoneBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource DiabloEmberBrush}" />
        <Setter Property="SelectionBrush" Value="#7FFF7A29" />
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border
                        x:Name="Bd"
                        Background="{StaticResource DiabloGrooveBrush}"
                        BorderThickness="1.5"
                        CornerRadius="3">
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="Edge" Color="#5A4128" />
                        </Border.BorderBrush>
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Edge"
                                            Storyboard.TargetProperty="Color"
                                            To="#FF7A29"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Edge"
                                            Storyboard.TargetProperty="Color"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ ComboBox: an aged grimoire unfurling ============  -->
    <Style x:Key="DiabloComboToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border
                        x:Name="Bd"
                        Background="{StaticResource DiabloSlabBrush}"
                        BorderThickness="1.5"
                        CornerRadius="3">
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="Edge" Color="#5A4128" />
                        </Border.BorderBrush>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="26" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter
                                Grid.Column="0"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center" />
                            <Path
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M0,0 L4,4 L8,0 Z"
                                Fill="{StaticResource DiabloEmberBrush}"
                                RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="ArrowRot" />
                                </Path.RenderTransform>
                            </Path>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ArrowRot"
                                            Storyboard.TargetProperty="Angle"
                                            To="180"
                                            Duration="0:0:0.22" />
                                        <ColorAnimation
                                            Storyboard.TargetName="Edge"
                                            Storyboard.TargetProperty="Color"
                                            To="#FF7A29"
                                            Duration="0:0:0.22" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ArrowRot"
                                            Storyboard.TargetProperty="Angle"
                                            To="0"
                                            Duration="0:0:0.22" />
                                        <ColorAnimation
                                            Storyboard.TargetName="Edge"
                                            Storyboard.TargetProperty="Color"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{StaticResource DiabloBoneBrush}" />
        <Setter Property="Height" Value="36" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource DiabloFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton
                            Content="{TemplateBinding SelectionBoxItem}"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                            Style="{StaticResource DiabloComboToggle}" />
                        <Popup
                            x:Name="PART_Popup"
                            AllowsTransparency="True"
                            Focusable="False"
                            IsOpen="{TemplateBinding IsDropDownOpen}"
                            Placement="Bottom"
                            PopupAnimation="None">
                            <Border
                                x:Name="Grimoire"
                                MinWidth="{TemplateBinding ActualWidth}"
                                MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                Margin="0,6,0,0"
                                Background="{StaticResource DiabloGrimoireBrush}"
                                BorderBrush="{StaticResource DiabloBronzeBrush}"
                                BorderThickness="1.5"
                                CornerRadius="3"
                                RenderTransformOrigin="0.5,0">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="GrimoireScale" ScaleY="0.5" />
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="18"
                                        Opacity="0.6"
                                        ShadowDepth="4"
                                        Color="#000000" />
                                </Border.Effect>
                                <ScrollViewer Padding="3">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Grimoire"
                                            Storyboard.TargetProperty="Opacity"
                                            From="0"
                                            To="1"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="GrimoireScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            From="0.5"
                                            To="1"
                                            Duration="0:0:0.28">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Foreground" Value="{StaticResource DiabloBoneBrush}" />
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        CornerRadius="2">
                        <Border.Background>
                            <SolidColorBrush Color="Transparent" />
                        </Border.Background>
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#3A1E10"
                                            Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            Duration="0:0:0.22" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#5A1A0C" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource DiabloEmberBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ Slider: blackened iron groove + ember gem thumb ============  -->
    <Style TargetType="{x:Type Slider}">
        <Setter Property="FocusVisualStyle" Value="{StaticResource DiabloFocusVisual}" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid VerticalAlignment="Center" Background="Transparent">
                        <Border
                            Height="6"
                            Background="{StaticResource DiabloGrooveBrush}"
                            BorderBrush="{StaticResource DiabloBronzeBrush}"
                            BorderThickness="1"
                            CornerRadius="3" />
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{StaticResource DiabloTrackRepeatButton}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{StaticResource DiabloTrackRepeatButton}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource DiabloSliderThumb}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ ProgressBar: molten fill with a sweeping highlight ============  -->
    <Style TargetType="{x:Type ProgressBar}">
        <Setter Property="Height" Value="18" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Border
                        x:Name="PART_Track"
                        Background="{StaticResource DiabloGrooveBrush}"
                        BorderBrush="{StaticResource DiabloBronzeBrush}"
                        BorderThickness="1.5"
                        ClipToBounds="True"
                        CornerRadius="3">
                        <Grid>
                            <Border
                                x:Name="PART_Indicator"
                                HorizontalAlignment="Left"
                                ClipToBounds="True"
                                CornerRadius="2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#FFB259" />
                                        <GradientStop Offset="0.5" Color="#C8260C" />
                                        <GradientStop Offset="1" Color="#7A0F08" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Rectangle
                                    x:Name="Molten"
                                    Width="50"
                                    HorizontalAlignment="Left"
                                    RenderTransformOrigin="0,0">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#00FFD08A" />
                                            <GradientStop Offset="0.5" Color="#99FFD08A" />
                                            <GradientStop Offset="1" Color="#00FFD08A" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform x:Name="MoltenMove" X="-50" />
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Border>
                            <Border
                                x:Name="IndetWave"
                                Width="90"
                                HorizontalAlignment="Left"
                                CornerRadius="2"
                                RenderTransformOrigin="0,0"
                                Visibility="Collapsed">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0" Color="#00C8260C" />
                                        <GradientStop Offset="0.5" Color="#FFFF7A29" />
                                        <GradientStop Offset="1" Color="#00C8260C" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="WaveMove" X="-90" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        RepeatBehavior="Forever"
                                        Storyboard.TargetName="MoltenMove"
                                        Storyboard.TargetProperty="X"
                                        From="-50"
                                        To="320"
                                        Duration="0:0:2.4" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="IndetWave" Property="Visibility" Value="Visible" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="WaveMove"
                                            Storyboard.TargetProperty="X"
                                            From="-90"
                                            To="340"
                                            Duration="0:0:1.5">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ ScrollBar: wrought iron with spiked thumb ============  -->
    <ControlTemplate x:Key="DiabloScrollVertical" TargetType="{x:Type ScrollBar}">
        <Grid Background="Transparent" SnapsToDevicePixels="True">
            <Border
                Width="4"
                HorizontalAlignment="Center"
                Background="{StaticResource DiabloGrooveBrush}"
                CornerRadius="2" />
            <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Style="{StaticResource DiabloTrackRepeatButton}" />
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Style="{StaticResource DiabloTrackRepeatButton}" />
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb
                        Width="10"
                        MinHeight="28"
                        Style="{StaticResource DiabloScrollThumb}" />
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="DiabloScrollHorizontal" TargetType="{x:Type ScrollBar}">
        <Grid Background="Transparent" SnapsToDevicePixels="True">
            <Border
                Height="4"
                VerticalAlignment="Center"
                Background="{StaticResource DiabloGrooveBrush}"
                CornerRadius="2" />
            <Track x:Name="PART_Track" IsDirectionReversed="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Style="{StaticResource DiabloTrackRepeatButton}" />
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Style="{StaticResource DiabloTrackRepeatButton}" />
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb
                        Height="10"
                        MinWidth="28"
                        Style="{StaticResource DiabloScrollThumb}" />
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Width" Value="12" />
        <Setter Property="MinWidth" Value="12" />
        <Setter Property="Template" Value="{StaticResource DiabloScrollVertical}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Height" Value="12" />
                <Setter Property="MinHeight" Value="12" />
                <Setter Property="Template" Value="{StaticResource DiabloScrollHorizontal}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  ============ TabControl + TabItem: a burning underline ============  -->
    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TabPanel
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            IsItemsHost="True" />
                        <Border
                            Grid.Row="1"
                            Background="{StaticResource ThemeCardBrush}"
                            BorderBrush="{StaticResource DiabloBronzeBrush}"
                            BorderThickness="1.5"
                            CornerRadius="3">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="{StaticResource DiabloBoneDimBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Grid Background="Transparent">
                        <ContentPresenter Margin="16,9" ContentSource="Header" />
                        <Rectangle
                            x:Name="Underline"
                            Height="2.5"
                            VerticalAlignment="Bottom"
                            RadiusX="1"
                            RadiusY="1"
                            RenderTransformOrigin="0.5,0.5">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#C8260C" />
                                    <GradientStop Offset="0.5" Color="#FFB259" />
                                    <GradientStop Offset="1" Color="#C8260C" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                            <Rectangle.RenderTransform>
                                <ScaleTransform x:Name="UnderlineScale" ScaleX="0" />
                            </Rectangle.RenderTransform>
                            <Rectangle.Effect>
                                <DropShadowEffect
                                    BlurRadius="6"
                                    Opacity="0.7"
                                    ShadowDepth="0"
                                    Color="#FF7A29" />
                            </Rectangle.Effect>
                        </Rectangle>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DiabloBoneBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource DiabloEmberBrush}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="UnderlineScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="UnderlineScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ ListBox + ListBoxItem: torchlight sweep on hover ============  -->
    <Style TargetType="{x:Type ListBox}">
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Background" Value="{StaticResource DiabloGrooveBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DiabloBronzeBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBox}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="3">
                        <ScrollViewer Padding="{TemplateBinding Padding}">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Foreground" Value="{StaticResource DiabloBoneBrush}" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border
                        x:Name="Bd"
                        Padding="{TemplateBinding Padding}"
                        CornerRadius="2">
                        <Border.Background>
                            <SolidColorBrush Color="Transparent" />
                        </Border.Background>
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#33FF7A29"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#5A1A0C" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource DiabloEmberBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ Expander: a crypt door with a flickering brazier ember ============  -->
    <Style TargetType="{x:Type Expander}">
        <Setter Property="Foreground" Value="{StaticResource DiabloBoneBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Expander}">
                    <Border
                        Background="{StaticResource ThemeCardBrush}"
                        BorderBrush="{StaticResource DiabloBronzeBrush}"
                        BorderThickness="1.5"
                        CornerRadius="3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <ToggleButton Grid.Row="0" IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Padding="12,10" Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse
                                                    x:Name="Brazier"
                                                    Width="12"
                                                    Height="12"
                                                    VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <RadialGradientBrush>
                                                            <GradientStop Offset="0" Color="#FFB259" />
                                                            <GradientStop Offset="1" Color="#B34A10" />
                                                        </RadialGradientBrush>
                                                    </Ellipse.Fill>
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect
                                                            x:Name="BrazierGlow"
                                                            BlurRadius="8"
                                                            Opacity="0.7"
                                                            ShadowDepth="0"
                                                            Color="#FF7A29" />
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <Path
                                                    x:Name="Arrow"
                                                    Margin="9,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Data="M0,0 L4,4 L8,0 Z"
                                                    Fill="{StaticResource DiabloEmberBrush}"
                                                    RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform x:Name="ArrowRot" Angle="-90" />
                                                    </Path.RenderTransform>
                                                </Path>
                                                <ContentPresenter
                                                    Margin="9,0,0,0"
                                                    VerticalAlignment="Center"
                                                    ContentSource="Content" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            AutoReverse="True"
                                                            RepeatBehavior="Forever"
                                                            Storyboard.TargetName="BrazierGlow"
                                                            Storyboard.TargetProperty="(DropShadowEffect.BlurRadius)"
                                                            To="16"
                                                            Duration="0:0:0.7">
                                                            <DoubleAnimation.EasingFunction>
                                                                <SineEase EasingMode="EaseInOut" />
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="ArrowRot"
                                                                Storyboard.TargetProperty="Angle"
                                                                To="0"
                                                                Duration="0:0:0.28">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <BackEase Amplitude="0.4" EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="ArrowRot"
                                                                Storyboard.TargetProperty="Angle"
                                                                To="-90"
                                                                Duration="0:0:0.28" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Border Grid.Row="1" RenderTransformOrigin="0.5,0">
                                <Border.LayoutTransform>
                                    <ScaleTransform x:Name="CryptScale" ScaleY="0" />
                                </Border.LayoutTransform>
                                <ContentPresenter Margin="12,0,12,12" />
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="CryptScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="CryptScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0"
                                            Duration="0:0:0.22" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
