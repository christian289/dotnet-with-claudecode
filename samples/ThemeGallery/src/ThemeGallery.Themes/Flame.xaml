<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        FLAME theme — charcoal with a warm glow rising from the bottom, ash-white
        text, fire orange/yellow accents. Self-contained per THEME-CONTRACT.md.
        Animated brushes are always declared inline. Signature ambient animation:
        flames flicker on Button hover, a candle flicker on a checked CheckBox, and
        a burning-fuse combustion point sweeps the ProgressBar.
    -->

    <!--  Palette  -->
    <Color x:Key="ColAsh">#F0E7DD</Color>
    <Color x:Key="ColAshDim">#A99F94</Color>
    <Color x:Key="ColFire">#FF6A00</Color>
    <Color x:Key="ColFireYellow">#FFC400</Color>
    <Color x:Key="ColEmber">#FF3D00</Color>
    <Color x:Key="ColChar">#1C1714</Color>
    <Color x:Key="ColCharDeep">#0E0B09</Color>
    <Color x:Key="ColCoal">#262019</Color>

    <!--  Shell brush keys (consumed by the gallery window)  -->
    <LinearGradientBrush x:Key="ThemeWindowBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="#0C0A08" />
        <GradientStop Offset="0.55" Color="#13100C" />
        <GradientStop Offset="0.85" Color="#2A1608" />
        <GradientStop Offset="1" Color="#451E07" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ThemeTextBrush" Color="{StaticResource ColAsh}" />
    <SolidColorBrush x:Key="ThemeSubtleTextBrush" Color="{StaticResource ColAshDim}" />
    <SolidColorBrush x:Key="ThemeAccentBrush" Color="{StaticResource ColFire}" />
    <LinearGradientBrush x:Key="ThemeCardBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#211A15" />
        <GradientStop Offset="1" Color="#15100C" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ThemeBorderBrush" Color="#4A3322" />

    <!--  Shared static brushes (never animated — animated brushes are inline)  -->
    <SolidColorBrush x:Key="FlameAshBrush" Color="{StaticResource ColAsh}" />
    <SolidColorBrush x:Key="FlameAshDimBrush" Color="{StaticResource ColAshDim}" />
    <SolidColorBrush x:Key="FlameFireBrush" Color="{StaticResource ColFire}" />
    <SolidColorBrush x:Key="FlameBorderBrush" Color="#4A3322" />
    <LinearGradientBrush x:Key="FlameCoalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#332821" />
        <GradientStop Offset="0.5" Color="#231B15" />
        <GradientStop Offset="1" Color="#140F0B" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="FlameFireGradient" StartPoint="0,1" EndPoint="0,0">
        <GradientStop Offset="0" Color="#FF3D00" />
        <GradientStop Offset="0.5" Color="#FF6A00" />
        <GradientStop Offset="1" Color="#FFC400" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="FlameGrooveBrush" Color="#0E0B09" />

    <!--  Flame geometry reused by flickering decorations  -->
    <PathGeometry x:Key="FlameGeo" Figures="M8,20 C2,14 5,9 8,0 C11,9 14,14 8,20 Z" />

    <!--  Keyboard focus cue  -->
    <Style x:Key="FlameFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle
                        Margin="-3"
                        RadiusX="3"
                        RadiusY="3"
                        SnapsToDevicePixels="True"
                        Stroke="{StaticResource FlameFireBrush}"
                        StrokeDashArray="1 2"
                        StrokeThickness="1" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Transparent repeat button for Slider / ScrollBar tracks  -->
    <Style x:Key="FlameTrackRepeat" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Slider thumb: a glowing ember bead  -->
    <Style x:Key="FlameEmberThumb" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid
                        Width="22"
                        Height="22"
                        Background="Transparent">
                        <Ellipse
                            x:Name="Bead"
                            Width="16"
                            Height="16">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.4,0.35">
                                    <GradientStop Offset="0" Color="#FFE9A6" />
                                    <GradientStop Offset="0.55" Color="#FF6A00" />
                                    <GradientStop Offset="1" Color="#B32700" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Effect>
                                <DropShadowEffect
                                    x:Name="BeadGlow"
                                    BlurRadius="8"
                                    Opacity="0.5"
                                    ShadowDepth="0"
                                    Color="#FF6A00" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="BeadHoverBSB">
                                    <Storyboard>
                                        <DoubleAnimation
                                            AutoReverse="True"
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="BeadGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.BlurRadius)"
                                            To="18"
                                            Duration="0:0:0.5" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="BeadHoverBSB" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="BeadGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.BlurRadius)"
                                            To="8"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="BeadGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.BlurRadius)"
                                            To="20"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="BeadGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.BlurRadius)"
                                            To="8"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ScrollBar thumb: heated iron rod (glows on hover)  -->
    <Style x:Key="FlameRodThumb" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border
                        x:Name="Rod"
                        CornerRadius="5"
                        SnapsToDevicePixels="True">
                        <Border.Background>
                            <SolidColorBrush Color="#5A4636" />
                        </Border.Background>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Rod"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#FF6A00"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Rod"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            Duration="0:0:0.4" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ Button: a coal block, flames lick up on hover ============  -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource FlameAshBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="20,9" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FlameFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="CoalScale" />
                        </Grid.RenderTransform>
                        <!--  flames behind the top edge  -->
                        <Canvas
                            x:Name="Flames"
                            Height="0"
                            VerticalAlignment="Top"
                            Opacity="0">
                            <Path
                                x:Name="Flame1"
                                Canvas.Left="14"
                                Canvas.Top="-14"
                                Width="12"
                                Height="22"
                                Data="{StaticResource FlameGeo}"
                                Fill="{StaticResource FlameFireGradient}"
                                RenderTransformOrigin="0.5,1"
                                Stretch="Fill">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="Flame1S" ScaleY="1" />
                                </Path.RenderTransform>
                            </Path>
                            <Path
                                x:Name="Flame2"
                                Canvas.Left="34"
                                Canvas.Top="-18"
                                Width="14"
                                Height="26"
                                Data="{StaticResource FlameGeo}"
                                Fill="{StaticResource FlameFireGradient}"
                                RenderTransformOrigin="0.5,1"
                                Stretch="Fill">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="Flame2S" ScaleY="1" />
                                </Path.RenderTransform>
                            </Path>
                            <Path
                                x:Name="Flame3"
                                Canvas.Left="56"
                                Canvas.Top="-13"
                                Width="11"
                                Height="20"
                                Data="{StaticResource FlameGeo}"
                                Fill="{StaticResource FlameFireGradient}"
                                RenderTransformOrigin="0.5,1"
                                Stretch="Fill">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="Flame3S" ScaleY="1" />
                                </Path.RenderTransform>
                            </Path>
                        </Canvas>
                        <Border
                            x:Name="Coal"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Border.Background>
                                <SolidColorBrush x:Name="CoalFill" Color="#241C16" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="CoalEdge" Color="#4A3322" />
                            </Border.BorderBrush>
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="HeatBSB">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Flames"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.25" />
                                        <ColorAnimation
                                            Storyboard.TargetName="CoalFill"
                                            Storyboard.TargetProperty="Color"
                                            To="#5A2207"
                                            Duration="0:0:0.3" />
                                        <ColorAnimation
                                            Storyboard.TargetName="CoalEdge"
                                            Storyboard.TargetProperty="Color"
                                            To="#FF6A00"
                                            Duration="0:0:0.3" />
                                        <DoubleAnimation
                                            AutoReverse="True"
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="Flame1S"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.6"
                                            Duration="0:0:0.28" />
                                        <DoubleAnimation
                                            AutoReverse="True"
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="Flame2S"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.7"
                                            Duration="0:0:0.22" />
                                        <DoubleAnimation
                                            AutoReverse="True"
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="Flame3S"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.55"
                                            Duration="0:0:0.33" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="HeatBSB" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Flames"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.3" />
                                        <ColorAnimation
                                            Storyboard.TargetName="CoalFill"
                                            Storyboard.TargetProperty="Color"
                                            Duration="0:0:0.4" />
                                        <ColorAnimation
                                            Storyboard.TargetName="CoalEdge"
                                            Storyboard.TargetProperty="Color"
                                            Duration="0:0:0.4" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="CoalFill"
                                            Storyboard.TargetProperty="Color"
                                            To="#FFB259"
                                            Duration="0:0:0.1" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="CoalScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.95"
                                            Duration="0:0:0.1" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="CoalScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.95"
                                            Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="CoalFill"
                                            Storyboard.TargetProperty="Color"
                                            To="#5A2207"
                                            Duration="0:0:0.25" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="CoalScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="CoalScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Coal" Property="Opacity" Value="0.4" />
                            <Setter Property="Foreground" Value="{StaticResource FlameAshDimBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ ToggleButton: ignites when on ============  -->
    <Style TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{StaticResource FlameAshBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="18,8" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FlameFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border
                        x:Name="Bd"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Border.Background>
                            <SolidColorBrush x:Name="Fill" Color="#241C16" />
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="Edge" Color="#4A3322" />
                        </Border.BorderBrush>
                        <ContentPresenter
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Fill"
                                            Storyboard.TargetProperty="Color"
                                            To="#7A3008"
                                            Duration="0:0:0.3" />
                                        <ColorAnimation
                                            Storyboard.TargetName="Edge"
                                            Storyboard.TargetProperty="Color"
                                            To="#FFC400"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Fill"
                                            Storyboard.TargetProperty="Color"
                                            Duration="0:0:0.3" />
                                        <ColorAnimation
                                            Storyboard.TargetName="Edge"
                                            Storyboard.TargetProperty="Color"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ CheckBox: a match strikes and settles into a candle flicker ============  -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource FlameAshBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FlameFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <StackPanel Background="Transparent" Orientation="Horizontal">
                        <Border
                            Width="22"
                            Height="22"
                            VerticalAlignment="Center"
                            Background="{StaticResource FlameGrooveBrush}"
                            BorderBrush="{StaticResource FlameBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3">
                            <Path
                                x:Name="Flame"
                                Width="11"
                                Height="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="{StaticResource FlameGeo}"
                                Fill="{StaticResource FlameFireGradient}"
                                RenderTransformOrigin="0.5,1"
                                Stretch="Fill">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="FlameScale" ScaleX="0" ScaleY="0" />
                                </Path.RenderTransform>
                                <Path.Effect>
                                    <DropShadowEffect
                                        x:Name="FlameGlow"
                                        BlurRadius="8"
                                        Opacity="0"
                                        ShadowDepth="0"
                                        Color="#FF6A00" />
                                </Path.Effect>
                            </Path>
                        </Border>
                        <ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="StrikeBSB">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="FlameScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.5" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="FlameScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.5" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="FlameGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.Opacity)"
                                            To="0.9"
                                            Duration="0:0:0.2" />
                                        <!--  candle flicker after the strike  -->
                                        <DoubleAnimation
                                            AutoReverse="True"
                                            BeginTime="0:0:0.25"
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="FlameScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.85"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="StrikeBSB" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="FlameScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="FlameScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="FlameGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.Opacity)"
                                            To="0"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ RadioButton: a burning wick dot with a halo pulse ============  -->
    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{StaticResource FlameAshBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FlameFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <StackPanel Background="Transparent" Orientation="Horizontal">
                        <Grid
                            Width="22"
                            Height="22"
                            VerticalAlignment="Center">
                            <Ellipse
                                Width="20"
                                Height="20"
                                Fill="{StaticResource FlameGrooveBrush}"
                                Stroke="{StaticResource FlameBorderBrush}"
                                StrokeThickness="1" />
                            <Ellipse
                                x:Name="Wick"
                                Width="10"
                                Height="10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Offset="0" Color="#FFE9A6" />
                                        <GradientStop Offset="1" Color="#FF3D00" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="WickScale" ScaleX="0" ScaleY="0" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect
                                        x:Name="WickGlow"
                                        BlurRadius="8"
                                        Opacity="0"
                                        ShadowDepth="0"
                                        Color="#FF6A00" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="WickBSB">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="WickScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.5" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="WickScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.5" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            AutoReverse="True"
                                            BeginTime="0:0:0.3"
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="WickGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.BlurRadius)"
                                            To="16"
                                            Duration="0:0:0.6" />
                                        <DoubleAnimation
                                            BeginTime="0:0:0.3"
                                            Storyboard.TargetName="WickGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.Opacity)"
                                            To="0.9"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="WickBSB" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="WickScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="WickScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0"
                                            Duration="0:0:0.2" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="WickGlow"
                                            Storyboard.TargetProperty="(DropShadowEffect.Opacity)"
                                            To="0"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ TextBox: rim ignites orange on focus ============  -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{StaticResource FlameAshBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource FlameFireBrush}" />
        <Setter Property="SelectionBrush" Value="#7FFF6A00" />
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border
                        x:Name="Bd"
                        Background="{StaticResource FlameGrooveBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="Edge" Color="#4A3322" />
                        </Border.BorderBrush>
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Edge"
                                            Storyboard.TargetProperty="Color"
                                            To="#FF6A00"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Edge"
                                            Storyboard.TargetProperty="Color"
                                            Duration="0:0:0.35" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
