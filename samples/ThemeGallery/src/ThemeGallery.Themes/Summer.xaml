<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ============================================================  -->
    <!--  SUMMER — ocean & beach. Sky-to-sea gradient, sandy shore,  -->
    <!--  coral / sun-yellow accents, water-fill progress, beach-ball  -->
    <!--  buttons, surfboard tabs & scrollbars.  -->
    <!--  ============================================================  -->

    <!--  Shell brush contract  -->
    <LinearGradientBrush x:Key="ThemeWindowBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0.00" Color="#7BDFF8" />
        <GradientStop Offset="0.38" Color="#3CC6F0" />
        <GradientStop Offset="0.60" Color="#15AEDC" />
        <GradientStop Offset="0.78" Color="#0CB9B4" />
        <GradientStop Offset="0.85" Color="#F2E2AE" />
        <GradientStop Offset="1.00" Color="#E7CF8D" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ThemeTextBrush" Color="#0A2E4D" />
    <SolidColorBrush x:Key="ThemeSubtleTextBrush" Color="#33617E" />
    <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FF6F61" />
    <SolidColorBrush x:Key="ThemeCardBrush" Color="#EAFDF8E9" />
    <SolidColorBrush x:Key="ThemeBorderBrush" Color="#0E8FA8" />

    <!--  Static helper brushes (never animated — animated brushes are inline)  -->
    <SolidColorBrush x:Key="SummerNavyBrush" Color="#0A2E4D" />
    <SolidColorBrush x:Key="SummerCoralBrush" Color="#FF6F61" />
    <SolidColorBrush x:Key="SummerSunBrush" Color="#FFD54F" />
    <SolidColorBrush x:Key="SummerTurquoiseBrush" Color="#00BCD4" />
    <SolidColorBrush x:Key="SummerDeepSeaBrush" Color="#0277BD" />
    <SolidColorBrush x:Key="SummerSandBrush" Color="#F4E6BC" />
    <SolidColorBrush x:Key="SummerFoamBrush" Color="#D8F7F3" />

    <!--  Shared focus cue  -->
    <Style x:Key="SummerFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle
                        Margin="-3"
                        RadiusX="6"
                        RadiusY="6"
                        SnapsToDevicePixels="True"
                        Stroke="#FF6F61"
                        StrokeDashArray="2 2"
                        StrokeThickness="1.5" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Transparent repeat button for Slider / ScrollBar tracks  -->
    <Style x:Key="SummerTrackRepeatButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ BUTTON — beach ball / wet pebble ============  -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource SummerNavyBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="20,9" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Grid
                        x:Name="Root"
                        RenderTransformOrigin="0.5,0.5"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="PressScale" />
                                <TranslateTransform x:Name="Bob" />
                            </TransformGroup>
                        </Grid.RenderTransform>
                        <!--  splash ripple ring (press)  -->
                        <Ellipse
                            x:Name="Ripple"
                            Width="26"
                            Height="26"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0.5"
                            StrokeThickness="3">
                            <Ellipse.Stroke>
                                <SolidColorBrush Color="#E0FFFF" />
                            </Ellipse.Stroke>
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="RippleScale" ScaleX="0.3" ScaleY="0.3" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Border
                            x:Name="Ball"
                            BorderThickness="1.5"
                            CornerRadius="16">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#0E8FA8" />
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0.0" Color="#FFF6D8" />
                                    <GradientStop Offset="0.45" Color="#FFD54F" />
                                    <GradientStop Offset="0.46" Color="#FF8A7A" />
                                    <GradientStop Offset="1.0" Color="#FF6F61" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid ClipToBounds="True">
                                <!--  sun-glare sweep (hover)  -->
                                <Rectangle
                                    x:Name="Glare"
                                    Width="42"
                                    HorizontalAlignment="Left"
                                    IsHitTestVisible="False"
                                    Opacity="0">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#00FFFFFF" />
                                            <GradientStop Offset="0.5" Color="#CCFFFFFF" />
                                            <GradientStop Offset="1" Color="#00FFFFFF" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <SkewTransform AngleX="-18" />
                                            <TranslateTransform x:Name="GlareShift" X="-70" />
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <!--  keyboard focus ring  -->
                        <Border
                            x:Name="FocusRing"
                            Margin="-3"
                            BorderBrush="{StaticResource SummerSunBrush}"
                            BorderThickness="2"
                            CornerRadius="19"
                            IsHitTestVisible="False"
                            Opacity="0" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!--  glare sweeps across  -->
                                        <DoubleAnimation
                                            Storyboard.TargetName="GlareShift"
                                            Storyboard.TargetProperty="X"
                                            From="-70"
                                            To="190"
                                            Duration="0:0:0.5">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Glare" Storyboard.TargetProperty="Opacity">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.12" Value="0.9" />
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <!--  bob once like floating on water  -->
                                        <DoubleAnimation
                                            AutoReverse="True"
                                            Storyboard.TargetName="Bob"
                                            Storyboard.TargetProperty="Y"
                                            To="-4"
                                            Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="GlareShift"
                                            Storyboard.TargetProperty="X"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glare"
                                            Storyboard.TargetProperty="Opacity"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Bob"
                                            Storyboard.TargetProperty="Y"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!--  splash: quick squash + expanding ripple ring  -->
                                        <DoubleAnimation
                                            Storyboard.TargetName="PressScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.93"
                                            Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PressScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.93"
                                            Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RippleScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            From="0.3"
                                            To="3.4"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RippleScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            From="0.3"
                                            To="3.4"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Ripple" Storyboard.TargetProperty="Opacity">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.75" />
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="0" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PressScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.5" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="PressScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.5" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RippleScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            Duration="0:0:0.1" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RippleScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            Duration="0:0:0.1" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Ripple"
                                            Storyboard.TargetProperty="Opacity"
                                            Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ TOGGLEBUTTON — day/night beach switch ============  -->
    <Style TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{StaticResource SummerNavyBrush}" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource SummerFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border
                        x:Name="Face"
                        Padding="{TemplateBinding Padding}"
                        BorderThickness="1.5"
                        CornerRadius="16"
                        RenderTransformOrigin="0.5,0.5"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="FaceScale" />
                        </Border.RenderTransform>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#0E8FA8" />
                        </Border.BorderBrush>
                        <Border.Background>
                            <SolidColorBrush Color="#D9FBFF" />
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <Grid
                                Width="44"
                                Height="22"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center">
                                <Border
                                    x:Name="SkyPill"
                                    BorderThickness="1"
                                    CornerRadius="11">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#0E8FA8" />
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <SolidColorBrush Color="#7BDFF8" />
                                    </Border.Background>
                                </Border>
                                <Ellipse
                                    x:Name="SunKnob"
                                    Width="18"
                                    Height="18"
                                    Margin="2,0"
                                    HorizontalAlignment="Left"
                                    StrokeThickness="1">
                                    <Ellipse.Stroke>
                                        <SolidColorBrush Color="#E8A33D" />
                                    </Ellipse.Stroke>
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="#FFD54F" />
                                    </Ellipse.Fill>
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform x:Name="KnobShift" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Face"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#F0FEFF"
                                            Duration="0:0:0.18">
                                            <ColorAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Face"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="#F2FBFF" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!--  sun slides to the other side of the beach  -->
                                        <DoubleAnimation
                                            Storyboard.TargetName="KnobShift"
                                            Storyboard.TargetProperty="X"
                                            To="22"
                                            Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.4" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!--  daylight tints to dusk  -->
                                        <ColorAnimation
                                            Storyboard.TargetName="SkyPill"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#123A63"
                                            Duration="0:0:0.3">
                                            <ColorAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <ColorAnimation
                                            Storyboard.TargetName="Face"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#16486B"
                                            Duration="0:0:0.3">
                                            <ColorAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <!--  sun pales into a moon  -->
                                        <ColorAnimation
                                            Storyboard.TargetName="SunKnob"
                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                            To="#F4F6E8"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="KnobShift"
                                            Storyboard.TargetProperty="X"
                                            Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.4" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <ColorAnimation
                                            Storyboard.TargetName="SkyPill"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            Duration="0:0:0.3" />
                                        <ColorAnimation
                                            Storyboard.TargetName="Face"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            Duration="0:0:0.3" />
                                        <ColorAnimation
                                            Storyboard.TargetName="SunKnob"
                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                            Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="FaceScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.95"
                                            Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="FaceScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.95"
                                            Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="FaceScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.4" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="FaceScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.4" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Face" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ CHECKBOX — starfish drops onto a sand circle ============  -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource SummerNavyBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource SummerFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <StackPanel
                        x:Name="Root"
                        Background="Transparent"
                        Orientation="Horizontal"
                        SnapsToDevicePixels="True">
                        <Grid
                            Width="20"
                            Height="20"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center">
                            <Ellipse x:Name="SandCircle" StrokeThickness="1.5">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="#F4E6BC" />
                                </Ellipse.Fill>
                                <Ellipse.Stroke>
                                    <SolidColorBrush Color="#0E8FA8" />
                                </Ellipse.Stroke>
                            </Ellipse>
                            <Path
                                x:Name="Starfish"
                                Width="14"
                                Height="14"
                                Data="M10,0 L12.6,6.9 L20,7.3 L14.2,11.9 L16.2,19 L10,14.8 L3.8,19 L5.8,11.9 L0,7.3 L7.4,6.9 Z"
                                Opacity="0"
                                RenderTransformOrigin="0.5,0.5"
                                Stretch="Uniform">
                                <Path.Fill>
                                    <SolidColorBrush Color="#FF6F61" />
                                </Path.Fill>
                                <Path.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="StarScale" ScaleX="0" ScaleY="0" />
                                        <TranslateTransform x:Name="StarDrop" Y="-10" />
                                    </TransformGroup>
                                </Path.RenderTransform>
                            </Path>
                        </Grid>
                        <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="SandCircle"
                                            Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                            To="#FF6F61"
                                            Duration="0:0:0.18">
                                            <ColorAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut" />
                                            </ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <ColorAnimation
                                            Storyboard.TargetName="SandCircle"
                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                            To="#FCF3D7"
                                            Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="SandCircle"
                                            Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                            Duration="0:0:0.2" />
                                        <ColorAnimation
                                            Storyboard.TargetName="SandCircle"
                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!--  starfish drops in with a bounce  -->
                                        <DoubleAnimation
                                            Storyboard.TargetName="Starfish"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.12" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="StarScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.8" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="StarScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.4">
                                            <DoubleAnimation.EasingFunction>
                                                <BackEase Amplitude="0.8" EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation
                                            Storyboard.TargetName="StarDrop"
                                            Storyboard.TargetProperty="Y"
                                            From="-10"
                                            To="0"
                                            Duration="0:0:0.45">
                                            <DoubleAnimation.EasingFunction>
                                                <BounceEase
                                                    Bounces="2"
                                                    Bounciness="2.5"
                                                    EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Starfish"
                                            Storyboard.TargetProperty="Opacity"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="StarScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="StarScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            Duration="0:0:0.15" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="StarDrop"
                                            Storyboard.TargetProperty="Y"
                                            Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ===== Thumb helpers for Slider & ScrollBar =====  -->
    <!--  Beach-ball slider thumb that spins while dragged/hovered  -->
    <Style x:Key="SummerBallThumb" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid
                        Width="24"
                        Height="24"
                        Background="Transparent">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <RotateTransform x:Name="BallRot" />
                            </Grid.RenderTransform>
                            <Ellipse Stroke="#FFFFFFFF" StrokeThickness="1">
                                <Ellipse.Fill>
                                    <RadialGradientBrush GradientOrigin="0.35,0.3">
                                        <GradientStop Offset="0" Color="#FFFFFFFF" />
                                        <GradientStop Offset="0.5" Color="#FF8AD8F0" />
                                        <GradientStop Offset="1" Color="#FF1E97C4" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Path
                                Data="M12,1 A11,11 0 0 1 12,23 M12,1 A11,11 0 0 0 12,23"
                                Stroke="#88FF6F61"
                                StrokeThickness="1.4" />
                            <Path
                                Data="M1,12 A11,11 0 0 1 23,12"
                                Stroke="#88FFD54F"
                                StrokeThickness="1.4" />
                        </Grid>
                        <Ellipse
                            x:Name="Glow"
                            Opacity="0"
                            Stroke="#FF6F61"
                            StrokeThickness="2" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="BallHoverBSB">
                                    <Storyboard>
                                        <DoubleAnimation
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="BallRot"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:2.5" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.7"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="BallHoverBSB" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glow"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="BallDragBSB">
                                    <Storyboard>
                                        <DoubleAnimation
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="BallRot"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:1.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="BallDragBSB" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Surfboard scrollbar thumb  -->
    <Style x:Key="SummerBoardThumb" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
