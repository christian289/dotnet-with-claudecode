{
  "description": "WPF Dev Pack hooks - .NET SDK version check, MCP dependency check, XAML validation, MVVM violation detection, build error diagnosis, code formatting, HandMirror API verification reminder, and per-project language preference loader (C# file-based apps, .NET SDK 10.0.300+ required). Note: feedback document anonymity audit and Microsoft skill creator reminder are wired through skill frontmatter, not here.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/DotnetVersionChecker.cs\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/LanguagePreferenceLoader.cs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_context7|mcp__claude_ai_Microsoft_Learn",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/HandMirrorReminder.cs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__.*WpfDevPackMcp.*",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/RepoPathGuard.cs\"",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/McpDependencyChecker.cs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.xaml)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/XamlValidator.cs\"",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Edit(*.cs)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/MvvmViolationDetector.cs\"",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Edit(*.cs)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/CodeFormatter.cs\"",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Edit(*.xaml)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/CodeFormatter.cs\"",
            "timeout": 45
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*.xaml)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/XamlValidator.cs\"",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Write(*.cs)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/MvvmViolationDetector.cs\"",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Write(*.cs)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/CodeFormatter.cs\"",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Write(*.xaml)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/CodeFormatter.cs\"",
            "timeout": 45
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/BuildErrorDiagnoser.cs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
