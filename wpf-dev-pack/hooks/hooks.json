{
  "description": "WPF Dev Pack hooks - MCP dependency check, WPF keyword detection, XAML validation, MVVM violation detection, build error diagnosis, code formatting, and HandMirror API verification reminder (C# file-based apps, .NET 10 required)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_context7|mcp__claude_ai_Microsoft_Learn",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/HandMirrorReminder.cs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/McpDependencyChecker.cs\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/WpfKeywordDetector.cs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(*.xaml)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/XamlValidator.cs\"",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Edit(*.cs)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/MvvmViolationDetector.cs\"",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Edit(*.cs)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/CodeFormatter.cs\"",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Edit(*.xaml)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/CodeFormatter.cs\"",
            "timeout": 45
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*.xaml)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/XamlValidator.cs\"",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Write(*.cs)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/MvvmViolationDetector.cs\"",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Write(*.cs)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/CodeFormatter.cs\"",
            "timeout": 45
          },
          {
            "type": "command",
            "if": "Write(*.xaml)",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/CodeFormatter.cs\"",
            "timeout": 45
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet \"${CLAUDE_PLUGIN_ROOT}/hooks/BuildErrorDiagnoser.cs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
